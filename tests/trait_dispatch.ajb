trait Display {
    fn show(self) -> string;
}

struct Counter {
    value: int
}

impl Display for Counter {
    fn show(self) -> string {
        return "Counter";
    }
}

function main() {
    set c = Counter { value: 42 };
    // Trait method dispatch
    set s = c.show();
    println(s);
    assert_eq(s, "Counter");
}
