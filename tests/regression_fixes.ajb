// ============================================================
// Regression tests for audit fixes
// Run with: cargo run tests/regression_fixes.ajb
// ============================================================

// --- B1: Division by zero should not panic ---
function test_div_by_zero(): void {
    let a: int = 5;
    let b: int = 0;
    let result: int = a / b;
    // Should print 0 instead of crashing
    println("B1 PASS: 5/0 = ", result);
}

// --- B2: !x operator should work for booleans ---
function test_not_operator(): void {
    let t: bool = true;
    let f: bool = false;

    if (!t) {
        println("B2 FAIL: !true should be false");
    } else {
        println("B2 PASS: !true = false");
    }

    if (!f) {
        println("B2 PASS: !false = true");
    } else {
        println("B2 FAIL: !false should be true");
    }

    // ! should also work on integers
    let z: int = 0;
    let nz: int = 42;
    if (!z) {
        println("B2 PASS: !0 = true");
    } else {
        println("B2 FAIL: !0 should be true");
    }
    if (!nz) {
        println("B2 FAIL: !42 should be false");
    } else {
        println("B2 PASS: !42 = false");
    }
}

// --- B3: Functions should access global variables ---
// IMPORTANT: global must be declared BEFORE the function that uses it
let global_val: int = 42;

function test_global_access(): int {
    return global_val;
}

function test_global_scope(): void {
    let result: int = test_global_access();
    if (result == 42) {
        println("B3 PASS: Global variable accessible from function = ", result);
    } else {
        println("B3 FAIL: Expected 42, got ", result);
    }
}

// --- B7: For loop should work correctly ---
function test_for_loop(): void {
    let sum: int = 0;
    for (let i: int = 0; i < 5; i = i + 1) {
        sum = sum + i;
    }
    // sum should be 0+1+2+3+4 = 10
    if (sum == 10) {
        println("B7 PASS: For loop sum = ", sum);
    } else {
        println("B7 FAIL: Expected 10, got ", sum);
    }
}

// --- M2: Nested arrays should print fully ---
function test_nested_array(): void {
    let arr: int[] = [1, [2, 3]];
    println("M2 PASS: Nested array = ", arr);
}

// --- Main ---
function main(): int {
    println("=== Ajeeb Regression Tests ===\n");

    test_div_by_zero();
    test_not_operator();
    test_global_scope();
    test_for_loop();
    test_nested_array();

    println("\n=== Tests Complete ===");
    return 0;
}
