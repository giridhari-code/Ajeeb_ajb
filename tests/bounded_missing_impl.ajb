trait Printable {
    fn format(self) -> string;
}

struct User {
    name: string
}

struct Post {
    title: string
}

impl Printable for User {
    fn format(self) -> string {
        return self.name;
    }
}

// User implements Printable, but Post does NOT

fn print_item[T: Printable](item: T) {
    let msg = item.format();
    println(msg);
}

function main() {
    let u = User { name: "Ajmal" };
    print_item[User](u);  // OK - User implements Printable

    let p = Post { title: "Hello" };
    print_item[Post](p);  // ERROR - Post does NOT implement Printable
}
