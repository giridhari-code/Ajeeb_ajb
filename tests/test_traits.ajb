trait Greeter {
    function greet(self: Person): String;
}

struct Person {
    name: String;
    age: Int;
}

impl Greeter for Person {
    function greet(self: Person): String {
        return self.name;
    }

}

function main(): Int {
    set p = Person { name: "Alice", age: 30 };
    set msg = p.greet();
    println(msg);
    assert_eq(msg, "Alice");
    return 0;
}

