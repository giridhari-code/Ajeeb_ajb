enum Option[T] {
    Some(T),
    None,
}

trait Optional[T] {
    function is_some(self, value: T) -> Bool;
}

impl Optional[Int] for Option[Int] {
    function is_some(self, value: Int) -> Bool {
        let result = match self {
            Option::Some(_) => true,
            Option::None => false,
        };
        return result;
    }
}

function main() {
    let some_val = Option[Int].Some(42);
    assert_eq(some_val.is_some(42), true);
    let none_val = Option[Int].None;
    assert_eq(none_val.is_some(0), false);
    println("PASS: generic_trait_option");
}
