// LLVM Feature Test: Arrays + Strings + Recursion (single arg println)
function factorial(n: int): int {
    if (n <= 1) { return 1; }
    return n * factorial(n - 1);
}

function main(): int {
    // Arrays
    let arr = [10, 20, 30, 40, 50];
    println(itoa(arr[0]));
    println(itoa(arr[2]));
    arr[1] = 99;
    println(itoa(arr[1]));

    // Strings
    let s1 = "Hello";
    let s2 = "World";
    let s3 = s1 + " " + s2;
    println(s3);

    // Recursion
    println(itoa(factorial(5)));
    println(itoa(factorial(10)));

    return 0;
}
