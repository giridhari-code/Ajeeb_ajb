// PASS: Generic enum with correct type arg count
enum Option[T] {
    Some(T),
    None,
}

function main() {
    let a = Option[Int].Some(10);
    let b = Option[String].Some("hi");

    let result = match a {
        Option::Some(n) => n,
        Option::None => 0,
    };
    assert_eq(result, 10);

    println("PASS: generic_enum_valid");
}
