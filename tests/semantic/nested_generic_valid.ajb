// PASS: Multiple generics with correct type args
struct Box[T] {
    value: T;
}

enum Option[T] {
    Some(T),
    None,
}

function wrap[T](x: T): T {
    return x;
}

function main() {
    set b = Box[Int] { value: 42 };
    assert_eq(b.value, 42);

    set opt = Option[Int].Some(10);
    set result = match opt {
        Option::Some(n) => n,
        Option::None => 0,
    };
    assert_eq(result, 10);

    set v = wrap[String]("hello");
    assert_eq(v, "hello");

    println("PASS: nested_generic_valid");
}
