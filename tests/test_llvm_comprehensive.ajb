// Comprehensive test for LLVM IR pipeline
// Tests all required AST node types

function main(): int {
    // Test 1: Let/Const declarations
    let x: int = 10;
    const y: int = 20;
    
    // Test 2: Binary expressions
    let sum = x + y;
    let diff = x - y;
    let prod = x * y;
    let quot = x / y;
    let eq = x == y;
    let neq = x != y;
    let lt = x < y;
    let gt = x > y;
    let le = x <= y;
    let ge = x >= y;
    let and = x == y && x < y;
    let or = x != y || x > y;
    
    // Test 3: If/Else
    if (x > 5) {
        println("x is greater than 5");
    } else {
        println("x is less than or equal to 5");
    }
    
    // Test 4: While loops
    let i = 0;
    while (i < 3) {
        println("while loop iteration ", i);
        i = i + 1;
    }
    
    // Test 5: For loops
    let sum_for = 0;
    for (let j = 0; j < 3; j = j + 1) {
        sum_for = sum_for + j;
    }
    
    // Test 6: Return statements
    if (sum > 100) {
        return 1;
    }
    
    // Test 7: String literals
    let str1 = "Hello";
    let str2 = "World";
    let str3 = str1 + " " + str2;
    println("Concatenated string ", str3);
    
    // Test 8: Function calls
    let result = len(str3);
    println("String length ", result);
    
    // Test 9: itoa builtin
    let num_str = itoa(42);
    println("Number as string ", num_str);
    
    // Test 10: Complex expression
    let complex = (x + y) * (x - y) / (x + y);
    println("Complex expression result ", complex);
    
    // Test 11: Nested if
    if (x > 0) {
        if (y > 0) {
            println("Both x and y are positive");
        } else {
            println("x is positive but y is not");
        }
    }
    
    // Test 12: Unary operations
    let neg_x = -x;
    let not_x = !x;
    println("Negated x ", neg_x);
    println("Not x ", not_x);
    
    return 0;
}