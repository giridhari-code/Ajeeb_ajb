// Ajeeb self-hosted C output
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <stdbool.h>
#include <stdint.h>

char __ajeeb_buf[16384];
char __ajeeb_outbuf[65536];

intptr_t getInt(intptr_t buf, intptr_t off);
void setInt(intptr_t buf, intptr_t off, intptr_t v);
intptr_t charCode(intptr_t s, intptr_t i);
intptr_t len(intptr_t s);
intptr_t readArg(intptr_t n);
intptr_t readFile(intptr_t path);
void writeFile(intptr_t path, intptr_t content);
void writeAppend(intptr_t path, intptr_t content);
void writeByte(intptr_t path, intptr_t byte);
intptr_t getOutbuf();
void strSet(intptr_t s, intptr_t i, intptr_t c);
intptr_t itoa(intptr_t n);
intptr_t println(intptr_t s);
intptr_t getStateBuf();
intptr_t strcmp_ajeeb(intptr_t a, intptr_t b);
intptr_t str_concat(intptr_t a, intptr_t b);
intptr_t substring(intptr_t s, intptr_t start, intptr_t end);
intptr_t indexOf(intptr_t s, intptr_t search);
intptr_t contains(intptr_t s, intptr_t search);
intptr_t toUpperCase(intptr_t s);
intptr_t toLowerCase(intptr_t s);
intptr_t trim(intptr_t s);
intptr_t replace(intptr_t s, intptr_t from, intptr_t to);
intptr_t startsWith(intptr_t s, intptr_t prefix);
intptr_t endsWith(intptr_t s, intptr_t suffix);
intptr_t parseExpr(intptr_t src, intptr_t buf, intptr_t out);
intptr_t parseStmt(intptr_t src, intptr_t buf, intptr_t out);

intptr_t rdB(intptr_t buf, intptr_t off) {
    return getInt(buf, off);
    return 0;
}

intptr_t wrB(intptr_t buf, intptr_t off, intptr_t v) {
    setInt(buf, off, v);
    return 0;
}

intptr_t rdPos(intptr_t buf) {
    return rdB(buf, 0);
    return 0;
}

intptr_t wrPos(intptr_t buf, intptr_t v) {
    wrB(buf, 0, v);
    return 0;
}

intptr_t rdFnC(intptr_t buf) {
    return rdB(buf, 16);
    return 0;
}

intptr_t wrFnC(intptr_t buf, intptr_t v) {
    wrB(buf, 16, v);
    return 0;
}

intptr_t rdSrc(intptr_t buf) {
    return rdB(buf, 32);
    return 0;
}

intptr_t wrSrc(intptr_t buf, intptr_t v) {
    wrB(buf, 32, v);
    return 0;
}

intptr_t savePos(intptr_t buf) {
    wrB(buf, 8, rdPos(buf));
    return 0;
}

intptr_t restorePos(intptr_t buf) {
    wrPos(buf, rdB(buf, 8));
    return 0;
}

intptr_t isDigit(intptr_t c) {
    if (c >= 48 && c <= 57) {
    return 1;
    }
    return 0;
    return 0;
}

intptr_t isAlpha(intptr_t c) {
    if (c >= 65 && c <= 90) {
    return 1;
    }
    if (c >= 97 && c <= 122) {
    return 1;
    }
    if (c == 95) {
    return 1;
    }
    return 0;
    return 0;
}

intptr_t isAlphaNum(intptr_t c) {
    if (isDigit(c) == 1) {
    return 1;
    }
    if (isAlpha(c) == 1) {
    return 1;
    }
    return 0;
    return 0;
}

intptr_t isSpace(intptr_t c) {
    if (c == 32 || c == 9 || c == 10 || c == 13) {
    return 1;
    }
    return 0;
    return 0;
}

intptr_t chr(intptr_t src, intptr_t i) {
    return charCode(src, i);
    return 0;
}

intptr_t skipWS(intptr_t src, intptr_t buf) {
    intptr_t pos = rdPos(buf);
    intptr_t go = 1;
    while (go == 1) {
    intptr_t c = chr(src, pos);
    if (isSpace(c) == 1) {
    pos = pos + 1;
    }
    else if (c == 47 && chr(src, pos + 1) == 47) {
    pos = pos + 2;
    while (chr(src, pos) != 10 && chr(src, pos) != 0) {
    pos = pos + 1;
    }
    }
    else if (c == 47 && chr(src, pos + 1) == 42) {
    pos = pos + 2;
    intptr_t dg = 1;
    while (dg == 1) {
    if (chr(src, pos) == 0) {
    dg = 0;
    }
    else if (chr(src, pos) == 42 && chr(src, pos + 1) == 47) {
    dg = 0;
    }
    else {
    pos = pos + 1;
    }
    }
    pos = pos + 2;
    }
    else {
    go = 0;
    }
    }
    wrPos(buf, pos);
    return 0;
}

intptr_t matchKwd(intptr_t src, intptr_t buf, intptr_t kwd) {
    intptr_t pos = rdPos(buf);
    intptr_t klen = len(kwd);
    intptr_t i = 0;
    while (i < klen) {
    if (chr(src, pos + i) != charCode(kwd, i)) {
    return 0;
    }
    i = i + 1;
    }
    if (isAlphaNum(chr(src, pos + klen)) == 1) {
    return 0;
    }
    return 1;
    return 0;
}

intptr_t readIdent(intptr_t src, intptr_t buf) {
    intptr_t pos = rdPos(buf);
    intptr_t start = pos;
    while (isAlphaNum(chr(src, pos)) == 1) {
    pos = pos + 1;
    }
    wrPos(buf, pos);
    return start;
    return 0;
}

intptr_t readNumber(intptr_t src, intptr_t buf) {
    intptr_t pos = rdPos(buf);
    intptr_t start = pos;
    while (isDigit(chr(src, pos)) == 1) {
    pos = pos + 1;
    }
    wrPos(buf, pos);
    intptr_t n = 0;
    intptr_t i = start;
    while (i < pos) {
    n = n * 10 + (chr(src, i) - 48);
    i = i + 1;
    }
    return n;
    return 0;
}

intptr_t readString(intptr_t src, intptr_t buf) {
    intptr_t pos = rdPos(buf);
    intptr_t start = pos + 1;
    pos = pos + 1;
    while (chr(src, pos) != 34 && chr(src, pos) != 0) {
    if (chr(src, pos) == 92) {
    pos = pos + 1;
    }
    pos = pos + 1;
    }
    pos = pos + 1;
    wrPos(buf, pos);
    return start;
    return 0;
}

intptr_t setTok(intptr_t buf, intptr_t typ, intptr_t val, intptr_t soff, intptr_t slen) {
    wrB(buf, 48, typ);
    wrB(buf, 56, val);
    wrB(buf, 64, soff);
    wrB(buf, 72, slen);
    return 0;
}

intptr_t tokType(intptr_t buf) {
    return rdB(buf, 48);
    return 0;
}

intptr_t tokVal(intptr_t buf) {
    return rdB(buf, 56);
    return 0;
}

intptr_t tokStrOff(intptr_t buf) {
    return rdB(buf, 64);
    return 0;
}

intptr_t tokStrLen(intptr_t buf) {
    return rdB(buf, 72);
    return 0;
}

intptr_t nextTok(intptr_t src, intptr_t buf) {
    skipWS(src, buf);
    intptr_t pos = rdPos(buf);
    intptr_t c = chr(src, pos);
    if (c == 0) {
    setTok(buf, 0, 0, 0, 0);
    return 0;
    }
    if (isAlpha(c) == 1 || c == 95) {
    intptr_t start = pos;
    readIdent(src, buf);
    intptr_t slen = rdPos(buf) - start;
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"let") == 1) {
    setTok(buf, 4, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"const") == 1) {
    setTok(buf, 5, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"if") == 1) {
    setTok(buf, 6, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"else") == 1) {
    setTok(buf, 7, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"while") == 1) {
    setTok(buf, 8, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"function") == 1) {
    setTok(buf, 9, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"return") == 1) {
    setTok(buf, 10, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"true") == 1) {
    setTok(buf, 11, 1, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"false") == 1) {
    setTok(buf, 12, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"int") == 1) {
    setTok(buf, 13, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"string") == 1) {
    setTok(buf, 14, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"bool") == 1) {
    setTok(buf, 15, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"void") == 1) {
    setTok(buf, 16, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"class") == 1) {
    setTok(buf, 42, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"self") == 1) {
    setTok(buf, 43, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"new") == 1) {
    setTok(buf, 44, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"for") == 1) {
    setTok(buf, 47, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"break") == 1) {
    setTok(buf, 45, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    savePos(buf);
    wrPos(buf, start);
    if (matchKwd(src, buf, (intptr_t)"continue") == 1) {
    setTok(buf, 46, 0, 0, 0);
    restorePos(buf);
    return 0;
    }
    restorePos(buf);
    setTok(buf, 1, 0, start, slen);
    return 0;
    }
    if (isDigit(c) == 1) {
    intptr_t val = readNumber(src, buf);
    setTok(buf, 2, val, 0, 0);
    return 0;
    }
    if (c == 34) {
    intptr_t start = readString(src, buf);
    intptr_t slen = rdPos(buf) - start - 1;
    setTok(buf, 3, 0, start, slen);
    return 0;
    }
    pos = pos + 1;
    wrPos(buf, pos);
    if (c == 43) {
    setTok(buf, 17, 0, 0, 0);
    return 0;
    }
    if (c == 45) {
    if (chr(src, pos) == 62) {
    wrPos(buf, pos + 1);
    setTok(buf, 33, 0, 0, 0);
    return 0;
    }
    setTok(buf, 18, 0, 0, 0);
    return 0;
    }
    if (c == 42) {
    setTok(buf, 19, 0, 0, 0);
    return 0;
    }
    if (c == 47) {
    setTok(buf, 20, 0, 0, 0);
    return 0;
    }
    if (c == 61) {
    if (chr(src, pos) == 61) {
    wrPos(buf, pos + 1);
    setTok(buf, 21, 0, 0, 0);
    return 0;
    }
    setTok(buf, 41, 0, 0, 0);
    return 0;
    }
    if (c == 33) {
    if (chr(src, pos) == 61) {
    wrPos(buf, pos + 1);
    setTok(buf, 22, 0, 0, 0);
    return 0;
    }
    setTok(buf, 29, 0, 0, 0);
    return 0;
    }
    if (c == 38) {
    if (chr(src, pos) == 38) {
    wrPos(buf, pos + 1);
    setTok(buf, 27, 0, 0, 0);
    return 0;
    }
    setTok(buf, 0, 0, 0, 0);
    return 0;
    }
    if (c == 124) {
    if (chr(src, pos) == 124) {
    wrPos(buf, pos + 1);
    setTok(buf, 28, 0, 0, 0);
    return 0;
    }
    setTok(buf, 0, 0, 0, 0);
    return 0;
    }
    if (c == 60) {
    if (chr(src, pos) == 61) {
    wrPos(buf, pos + 1);
    setTok(buf, 25, 0, 0, 0);
    return 0;
    }
    setTok(buf, 23, 0, 0, 0);
    return 0;
    }
    if (c == 62) {
    if (chr(src, pos) == 61) {
    wrPos(buf, pos + 1);
    setTok(buf, 26, 0, 0, 0);
    return 0;
    }
    setTok(buf, 24, 0, 0, 0);
    return 0;
    }
    if (c == 59) {
    setTok(buf, 30, 0, 0, 0);
    return 0;
    }
    if (c == 58) {
    setTok(buf, 31, 0, 0, 0);
    return 0;
    }
    if (c == 44) {
    setTok(buf, 32, 0, 0, 0);
    return 0;
    }
    if (c == 46) {
    setTok(buf, 34, 0, 0, 0);
    return 0;
    }
    if (c == 40) {
    setTok(buf, 35, 0, 0, 0);
    return 0;
    }
    if (c == 41) {
    setTok(buf, 36, 0, 0, 0);
    return 0;
    }
    if (c == 123) {
    setTok(buf, 37, 0, 0, 0);
    return 0;
    }
    if (c == 125) {
    setTok(buf, 38, 0, 0, 0);
    return 0;
    }
    if (c == 91) {
    setTok(buf, 39, 0, 0, 0);
    return 0;
    }
    if (c == 93) {
    setTok(buf, 40, 0, 0, 0);
    return 0;
    }
    setTok(buf, (-1), c, 0, 0);
    return 0;
}

intptr_t identStr(intptr_t src, intptr_t soff, intptr_t slen) {
    intptr_t scratch = getOutbuf();
    intptr_t i = 0;
    while (i < slen) {
    strSet(scratch, i, chr(src, soff + i));
    i = i + 1;
    }
    strSet(scratch, slen, 0);
    return scratch;
    return 0;
}

intptr_t emitStr(intptr_t out, intptr_t s) {
    writeAppend(out, s);
    return 0;
}

intptr_t emitI(intptr_t out, intptr_t n) {
    writeAppend(out, itoa(n));
    return 0;
}

intptr_t emitEscapedStr(intptr_t out, intptr_t src, intptr_t soff, intptr_t slen) {
    emitStr(out, (intptr_t)"(intptr_t)\"");
    intptr_t i = 0;
    while (i < slen) {
    intptr_t c = chr(src, soff + i);
    if (c == 10) {
    writeByte(out, 92);
    writeByte(out, 110);
    }
    else if (c == 9) {
    writeByte(out, 92);
    writeByte(out, 116);
    }
    else if (c == 34) {
    writeByte(out, 92);
    writeByte(out, 34);
    }
    else if (c == 92) {
    if (i + 1 < slen) {
    intptr_t next = chr(src, soff + i + 1);
    if (next == 110) {
    writeByte(out, 92);
    writeByte(out, 110);
    i = i + 1;
    }
    else if (next == 116) {
    writeByte(out, 92);
    writeByte(out, 116);
    i = i + 1;
    }
    else if (next == 48) {
    writeByte(out, 92);
    writeByte(out, 48);
    i = i + 1;
    }
    else if (next == 34) {
    writeByte(out, 92);
    writeByte(out, 34);
    i = i + 1;
    }
    else if (next == 92) {
    writeByte(out, 92);
    writeByte(out, 92);
    i = i + 1;
    }
    else {
    writeByte(out, 92);
    writeByte(out, next);
    i = i + 1;
    }
    }
    else {
    writeByte(out, 92);
    writeByte(out, 92);
    }
    }
    else {
    writeByte(out, c);
    }
    i = i + 1;
    }
    emitStr(out, (intptr_t)"\"");
    return 0;
}

intptr_t parsePrimary(intptr_t src, intptr_t buf, intptr_t out) {
    intptr_t t = tokType(buf);
    if (t == 2) {
    emitI(out, tokVal(buf));
    nextTok(src, buf);
    }
    else if (t == 3) {
    emitEscapedStr(out, src, tokStrOff(buf), tokStrLen(buf));
    nextTok(src, buf);
    }
    else if (t == 11) {
    emitStr(out, (intptr_t)"1");
    nextTok(src, buf);
    }
    else if (t == 12) {
    emitStr(out, (intptr_t)"0");
    nextTok(src, buf);
    }
    else if (t == 43) {
    nextTok(src, buf);
    intptr_t se = 0;
    intptr_t go = 1;
    while (go == 1) {
    t = tokType(buf);
    if (t == 34) {
    nextTok(src, buf);
    intptr_t fd = identStr(src, tokStrOff(buf), tokStrLen(buf));
    nextTok(src, buf);
    if (tokType(buf) == 35) {
    nextTok(src, buf);
    emitStr(out, fd);
    emitStr(out, (intptr_t)"(self");
    se = 1;
    intptr_t first = 1;
    while (tokType(buf) != 36 && tokType(buf) != 0) {
    if (first == 0) {
    emitStr(out, (intptr_t)", ");
    }
    first = 0;
    parseExpr(src, buf, out);
    if (tokType(buf) == 32) {
    nextTok(src, buf);
    }
    }
    emitStr(out, (intptr_t)")");
    if (tokType(buf) == 36) {
    nextTok(src, buf);
    }
    }
    else {
    emitStr(out, (intptr_t)"self->");
    emitStr(out, fd);
    se = 1;
    }
    }
    else if (t == 39) {
    nextTok(src, buf);
    emitStr(out, (intptr_t)"self[");
    se = 1;
    parseExpr(src, buf, out);
    emitStr(out, (intptr_t)"]");
    if (tokType(buf) == 40) {
    nextTok(src, buf);
    }
    }
    else if (t == 35) {
    nextTok(src, buf);
    emitStr(out, (intptr_t)"self(");
    se = 1;
    intptr_t first = 1;
    while (tokType(buf) != 36 && tokType(buf) != 0) {
    if (first == 0) {
    emitStr(out, (intptr_t)", ");
    }
    first = 0;
    parseExpr(src, buf, out);
    if (tokType(buf) == 32) {
    nextTok(src, buf);
    }
    }
    emitStr(out, (intptr_t)")");
    if (tokType(buf) == 36) {
    nextTok(src, buf);
    }
    }
    else {
    if (se == 0) {
    emitStr(out, (intptr_t)"self");
    }
    go = 0;
    }
    }
    }
    else if (t == 44) {
    nextTok(src, buf);
    intptr_t cn = identStr(src, tokStrOff(buf), tokStrLen(buf));
    nextTok(src, buf);
    emitStr(out, (intptr_t)"(");
    emitStr(out, cn);
    emitStr(out, (intptr_t)"){0}");
    }
    else if (t == 35) {
    nextTok(src, buf);
    emitStr(out, (intptr_t)"(");
    parseExpr(src, buf, out);
    emitStr(out, (intptr_t)")");
    if (tokType(buf) == 36) {
    nextTok(src, buf);
    }
    }
    else if (t == 39) {
    nextTok(src, buf);
    emitStr(out, (intptr_t)"{");
    intptr_t first = 1;
    while (tokType(buf) != 40 && tokType(buf) != 0) {
    if (first == 0) {
    emitStr(out, (intptr_t)", ");
    }
    first = 0;
    parseExpr(src, buf, out);
    if (tokType(buf) == 32) {
    nextTok(src, buf);
    }
    }
    emitStr(out, (intptr_t)"}");
    if (tokType(buf) == 40) {
    nextTok(src, buf);
    }
    }
    else if (t == 1) {
    intptr_t id = identStr(src, tokStrOff(buf), tokStrLen(buf));
    nextTok(src, buf);
    intptr_t emitted = 0;
    intptr_t go = 1;
    while (go == 1) {
    t = tokType(buf);
    if (t == 35) {
    if (emitted == 0) {
    emitStr(out, id);
    emitted = 1;
    }
    nextTok(src, buf);
    emitStr(out, (intptr_t)"(");
    intptr_t first = 1;
    while (tokType(buf) != 36 && tokType(buf) != 0) {
    if (first == 0) {
    emitStr(out, (intptr_t)", ");
    }
    first = 0;
    parseExpr(src, buf, out);
    if (tokType(buf) == 32) {
    nextTok(src, buf);
    }
    }
    emitStr(out, (intptr_t)")");
    if (tokType(buf) == 36) {
    nextTok(src, buf);
    }
    }
    else if (t == 34) {
    nextTok(src, buf);
    intptr_t fd = identStr(src, tokStrOff(buf), tokStrLen(buf));
    nextTok(src, buf);
