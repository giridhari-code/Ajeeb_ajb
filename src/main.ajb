intptr_t emitFwdDecls(intptr_t src, intptr_t buf, intptr_t out) {
    intptr_t count = rdFnC(buf);
    intptr_t i = 0;
    while (i < count) {
    intptr_t off = 96 + i * 24;
    intptr_t ns = rdB(buf, off);
    intptr_t nl = rdB(buf, off + 8);
    emitStr(out, (intptr_t)"intptr_t ");
    intptr_t j = 0;
    while (j < nl) {
    intptr_t ch = chr(src, ns + j);
    j = j + 1;
    intptr_t scratch = getOutbuf();
    strSet(scratch, 0, ch);
    strSet(scratch, 1, 0);
    writeAppend(out, scratch);
    }
    emitStr(out, (intptr_t)"();\n");
    i = i + 1;
    }
    return 0;
}

