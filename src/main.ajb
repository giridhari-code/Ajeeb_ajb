intptr_t addFn(intptr_t src, intptr_t buf, intptr_t nameStart) {
    intptr_t count = rdFnC(buf);
    if (count >= 600) {
    return 0;
    }
    intptr_t pos = rdPos(buf);
    intptr_t nameLen = pos - nameStart;
    intptr_t off = 96 + count * 24;
    setInt(buf, off, nameStart);
    setInt(buf, off + 8, nameLen);
    setInt(buf, off + 16, count);
    wrFnC(buf, count + 1);
    return 0;
}

intptr_t skipDepth(intptr_t src, intptr_t pos, intptr_t open, intptr_t close) {
    intptr_t depth = 1;
    pos = pos + 1;
    while (depth > 0) {
    intptr_t c = chr(src, pos);
    if (c == 34) {
    pos = pos + 1;
    while (chr(src, pos) != 34 && chr(src, pos) != 0) {
    if (chr(src, pos) == 92) {
    pos = pos + 1;
    }
    pos = pos + 1;
    }
    pos = pos + 1;
    }
    else if (c == 47 && chr(src, pos + 1) == 47) {
    pos = pos + 2;
    while (chr(src, pos) != 10 && chr(src, pos) != 0) {
    pos = pos + 1;
    }
    }
    else if (c == 47 && chr(src, pos + 1) == 42) {
    pos = pos + 2;
    while (chr(src, pos) != 0 && (!(chr(src, pos) == 42 && chr(src, pos + 1) == 47))) {
    pos = pos + 1;
    }
    pos = pos + 2;
    }
    else {
    if (c == open) {
    depth = depth + 1;
    }
    else if (c == close) {
    depth = depth - 1;
    }
    pos = pos + 1;
    }
    }
    return pos;
    return 0;
}

