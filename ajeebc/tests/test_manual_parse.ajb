function main(): int {
    set buf: string = getStateBuf();
    set out: string = "output.c";
    writeFile(out, "// test\n");

    set src: string = "function foo(): int { return 42; }";
    wrPos(buf, 0);
    nextTok(src, buf);

    set t: int = tokType(buf);
    writeAppend(out, itoa(t));
    writeAppend(out, "\n");

    // Also test chr directly
    set c: int = chr(src, 0);
    writeAppend(out, "chr0=");
    writeAppend(out, itoa(c));
    writeAppend(out, "\n");

    set isa: int = isAlpha(c);
    writeAppend(out, "isAlpha=");
    writeAppend(out, itoa(isa));
    writeAppend(out, "\n");
    return 0;
}
