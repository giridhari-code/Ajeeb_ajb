function isSpace(c: int): int { if (c == 32 || c == 9 || c == 10 || c == 13) { return 1; } return 0; }
function chr(src: int, i: int): int { return charCode(src, i); }
function main(): int {
    set buf: string = getStateBuf();
    set inPath: string = readArg(1);
    set src: string = readFile(inPath);
    set out: string = "build/debug_comment.txt";
    writeFile(out, "");
    set pos: int = 0;
    set c: int = chr(src, pos);
    writeAppend(out, "first_char=");
    writeAppend(out, itoa(c));
    writeAppend(out, "\n");
    while (isSpace(c) == 1) { pos = pos + 1; c = chr(src, pos); }
    writeAppend(out, "after_ws pos=");
    writeAppend(out, itoa(pos));
    writeAppend(out, " c=");
    writeAppend(out, itoa(c));
    writeAppend(out, "\n");
    return 0;
}
