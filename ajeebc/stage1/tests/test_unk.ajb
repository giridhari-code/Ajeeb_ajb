function main(): int {
    set src: string = readFile("tests/test_simple.ajb");
    set out: string = "build/debug_unk.txt";
    writeFile(out, "");
    set pos: int = 0;
    set c: int = charCode(src, pos);
    set j: int = 0;
    while (j < 50) {
        writeAppend(out, itoa(j));
        writeAppend(out, ": ");
        writeAppend(out, itoa(c));
        if (c >= 32 && c < 127) {
            writeAppend(out, " '");
            writeAppend(out, itoa(c));
            writeAppend(out, "'");
        }
        writeAppend(out, "\n");
        pos = pos + 1;
        c = charCode(src, pos);
        j = j + 1;
    }
    return 0;
}
