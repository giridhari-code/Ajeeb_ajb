function main(): int {
    set out: string = "build/debug_nested.txt";
    writeFile(out, "");
    set pos: int = 0;
    set go: int = 1;
    while (go == 1) {
        writeAppend(out, "outer pos=");
        writeAppend(out, itoa(pos));
        writeAppend(out, "\n");
        if (pos == 0) {
            set inner_pos: int = 5;
            while (inner_pos < 8) {
                writeAppend(out, "  inner pos=");
                writeAppend(out, itoa(inner_pos));
                writeAppend(out, "\n");
                inner_pos = inner_pos + 1;
            }
        }
        pos = pos + 1;
        if (pos > 3) { go = 0; }
    }
    writeAppend(out, "FINAL pos=");
    writeAppend(out, itoa(pos));
    writeAppend(out, "\n");
    return 0;
}
