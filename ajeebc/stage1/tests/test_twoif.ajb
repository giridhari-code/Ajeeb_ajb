function main(): int {
    set x: int = 0;
    while (x < 5) {
        if (x == 0) { x = 1; }
        if (x == 1) { x = 2; }
    }
    set out: string = "build/debug_twoif.txt";
    writeFile(out, "");
    writeAppend(out, "x=");
    writeAppend(out, itoa(x));
    writeAppend(out, "\n");
    return 0;
}
