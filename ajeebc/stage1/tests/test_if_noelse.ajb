function main(): int {
    set x: int = 0;
    while (x < 5) {
        if (x == 2) { x = x + 1; }
        x = x + 1;
    }
    set out: string = "build/debug_if_noelse.txt";
    writeFile(out, "");
    writeAppend(out, "x=");
    writeAppend(out, itoa(x));
    writeAppend(out, "\n");
    return 0;
}
