function main(): int {
    set out: string = "build/debug_andchain.txt";
    writeFile(out, "");
    set x: int = 5;
    set y: int = 1;
    while (x > 0) {
        if (x == 5 && y == 1) {
            writeAppend(out, "FIVE_AND_ONE\n");
        }
        else if (x == 3) {
            writeAppend(out, "THREE\n");
        }
        else {
            writeAppend(out, "OTHER\n");
        }
        x = x - 1;
    }
    return 0;
}
