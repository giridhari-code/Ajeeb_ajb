function main(): int {
    set x: int = 0;
    set c: int = 0;
    while (x < 5) {
        c = x;
        if (c == 0) x = 1;
        if (c == 1) x = 2;
        if (c == 2) x = 3;
        if (c == 3) x = 4;
        if (c == 4) x = 5;
    }
    set out: string = "build/debug_boundary.txt";
    writeFile(out, "");
    writeAppend(out, "x=");
    writeAppend(out, itoa(x));
    writeAppend(out, "\n");
    return 0;
}
