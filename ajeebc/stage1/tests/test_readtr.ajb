function main(): int {
    set src: string = readFile("tests/test_simple.ajb");
    set out: string = "build/debug_readtr.txt";
    writeFile(out, "");
    set pos: int = 0;
    set c: int = charCode(src, 0);
    writeAppend(out, "First 5 chars:\n");
    set j: int = 0;
    while (j < 5) {
        writeAppend(out, itoa(j));
        writeAppend(out, ": code=");
        writeAppend(out, itoa(c));
        writeAppend(out, "\n");
        pos = pos + 1;
        c = charCode(src, pos);
        j = j + 1;
    }
    writeAppend(out, "\nNow testing skipWS-like logic:\n");
    pos = 0;
    set go: int = 1;
    while (go == 1) {
        c = charCode(src, pos);
        if (c == 32 || c == 9 || c == 10 || c == 13) {
            writeAppend(out, "SPACE at ");
            writeAppend(out, itoa(pos));
            writeAppend(out, "\n");
            pos = pos + 1;
        }
        else if (c == 47 && charCode(src, pos + 1) == 47) {
            writeAppend(out, "LINECMT at ");
            writeAppend(out, itoa(pos));
            writeAppend(out, "\n");
            pos = pos + 2;
            while (charCode(src, pos) != 10 && charCode(src, pos) != 0) { pos = pos + 1; }
            writeAppend(out, "CMTEND at ");
            writeAppend(out, itoa(pos));
            writeAppend(out, "\n");
        }
        else {
            writeAppend(out, "STOP at ");
            writeAppend(out, itoa(pos));
            writeAppend(out, " code=");
            writeAppend(out, itoa(c));
            writeAppend(out, "\n");
            go = 0;
        }
    }
    return 0;
}
