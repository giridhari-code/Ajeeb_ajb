// eval.ajb — Piri MIR Interpreter Core
// Like Miri's machine.rs + eval.rs — stepBlock + execMirFn
// Types: 0=unknown 1=int 2=str 3=bool 5=void
// Mir opcodes: 1=Assign 2=Binop 4=Call 5=Return 6=Goto 7=Branch 9=ReadVar 11=Param 12=StrCat

function stepBlock(mirBuf: string, progOff: int, fnOff: int, src: string,
    regBuf: string, strPool: string, argsBuf: string, callerPool: string,
    curBlockIdx: int, varMap: string, varSlotNext: int,
    bc: int): int {
    // Returns: -2 = return, -1 = error, >=0 = next block

    if (curBlockIdx < 0 || curBlockIdx >= bc) { return -1; }

    set bo: int = mFnBlock(mirBuf, fnOff, curBlockIdx);
    set ic: int = mBlockInstrCount(mirBuf, bo);
    set tt: int = mBlockTermTy(mirBuf, bo);
    set t0: int = mBlockTerm0(mirBuf, bo);
    set t1: int = mBlockTerm1(mirBuf, bo);

    if (br(mirBuf, bo) != 2) { return -1; }

    set ji: int = 0;
    while (ji < ic) {
        set io: int = bo + 6 + ji * 6;
        set op: int = br(mirBuf, io + 1);
        set dst: int = br(mirBuf, io + 2);
        set s1: int = br(mirBuf, io + 3);
        set s2: int = br(mirBuf, io + 4);
        set ext: int = br(mirBuf, io + 5);

        if (op == 2) {
            if (s2 == 0 && ext == 101) {
                set sty: int = getRegType(regBuf, s1);
                if (sty == 0 || sty == 1 || sty == 3) {
                    setRegInt(regBuf, dst, getRegInt(regBuf, s1));
                } else {
                    setRegStr(regBuf, strPool, dst, getRegStr(regBuf, strPool, s1));
                }
            } else if (ext == 200) {
                setRegInt(regBuf, dst, s1);
            } else if (ext == 201) {
                setRegInt(regBuf, dst, s1);
            } else if (s2 != 0 && ext == 2) {
                setRegStr(regBuf, strPool, dst, substring(src, s1, s1 + s2));
            } else if (s2 != 0) {
                set v1: int = getRegInt(regBuf, s1);
                set v2: int = getRegInt(regBuf, s2);
                set res: int = 0;
                if (ext == 1) { res = v1 + v2; }
                else if (ext == 2) { res = v1 - v2; }
                else if (ext == 3) { res = v1 * v2; }
                else if (ext == 4) { if (v2 != 0) { res = v1 / v2; } }
                else if (ext == 5) {
                    set t1t: int = getRegType(regBuf, s1);
                    set t2t: int = getRegType(regBuf, s2);
                    if (t1t == 2 || t2t == 2) {
                        set s1s: string = getRegStr(regBuf, strPool, s1);
                        set s2s: string = getRegStr(regBuf, strPool, s2);
                        if (strcmp_ajeeb(s1s, s2s) == 0) { res = 1; }
                    } else {
                        if (v1 == v2) { res = 1; }
                    }
                }
                else if (ext == 6) {
                    set t1t: int = getRegType(regBuf, s1);
                    set t2t: int = getRegType(regBuf, s2);
                    if (t1t == 2 || t2t == 2) {
                        set s1s: string = getRegStr(regBuf, strPool, s1);
                        set s2s: string = getRegStr(regBuf, strPool, s2);
                        if (strcmp_ajeeb(s1s, s2s) != 0) { res = 1; }
                    } else {
                        if (v1 != v2) { res = 1; }
                    }
                }
                else if (ext == 7) { if (v1 < v2) { res = 1; } }
                else if (ext == 8) { if (v1 > v2) { res = 1; } }
                else if (ext == 9) { if (v1 <= v2) { res = 1; } }
                else if (ext == 10) { if (v1 >= v2) { res = 1; } }
                else if (ext == 11) { if (v1 != 0 && v2 != 0) { res = 1; } }
                else if (ext == 12) { if (v1 != 0 || v2 != 0) { res = 1; } }
                setRegInt(regBuf, dst, res);
            }
        } else if (op == 4) {
            set fnName: string = substring(src, s1, s1 + s2);
            set calleeFn: int = findFn(mirBuf, progOff, src, s1, s2);
            if (calleeFn >= 0) {
                set ac: int = callArgCount(ext);
                set calleeRegs: string = makeValBuf();
                set calleePool: string = allocBuf(80000);
                set calleeArgs: string = allocBuf(80000);
                set ai: int = 0;
                while (ai < ac) {
                    set srcReg: int = callArgAt(ext, ai);
                    set srcTy: int = getRegType(regBuf, srcReg);
                    if (srcTy == 0 || srcTy == 1 || srcTy == 3) {
                        bw(calleeArgs, ai * 4, getRegInt(regBuf, srcReg));
                        bw(calleeArgs, ai * 4 + 1, 0);
                        bw(calleeArgs, ai * 4 + 2, 0);
                        bw(calleeArgs, ai * 4 + 3, 1);
                    } else {
                        set sPos: int = br(regBuf, srcReg * 3 + 1);
                        set sLen: int = br(regBuf, srcReg * 3 + 2);
                        bw(calleeArgs, ai * 4, 0);
                        bw(calleeArgs, ai * 4 + 1, sPos);
                        bw(calleeArgs, ai * 4 + 2, sLen);
                        bw(calleeArgs, ai * 4 + 3, 2);
                    }
                    ai = ai + 1;
                }
                execMirFn(mirBuf, progOff, src, calleeFn,
                    calleeRegs, calleePool, calleeArgs, strPool, ac);
                set resTy: int = getRegType(calleeRegs, 0);
                if (resTy == 0 || resTy == 1 || resTy == 3) {
                    setRegInt(regBuf, dst, getRegInt(calleeRegs, 0));
                } else {
                    set resStr: string = getRegStr(calleeRegs, calleePool, 0);
                    setRegStr(regBuf, strPool, dst, resStr);
                }
            } else if (isBuiltin(fnName) == 1) {
                callBuiltin(regBuf, strPool, fnName, dst, ext);
            } else {
                setRegInt(regBuf, dst, 0);
            }
        } else if (op == 5) {
            set sty: int = getRegType(regBuf, s1);
            if (sty == 0 || sty == 1 || sty == 3) {
                setRegInt(regBuf, 0, getRegInt(regBuf, s1));
            } else {
                setRegStr(regBuf, strPool, 0, getRegStr(regBuf, strPool, s1));
            }
            return -2;
        } else if (op == 6) {
            return s1;
        } else if (op == 7) {
            set cond: int = getRegInt(regBuf, dst);
            if (cond != 0) { return s1; }
            else { return s2; }
        } else if (op == 9) {
            set vn: string = substring(src, s1, s1 + s2);
            set vs: int = getInt(varMap, vn);
            if (vs != 0) {
                set sty: int = getRegType(regBuf, vs);
                if (sty == 0 || sty == 1 || sty == 3) {
                    setRegInt(regBuf, dst, getRegInt(regBuf, vs));
                } else {
                    setRegStr(regBuf, strPool, dst, getRegStr(regBuf, strPool, vs));
                }
            } else {
                setRegInt(regBuf, dst, 0);
            }
        } else if (op == 11) {
            set argVal: int = br(argsBuf, s1 * 4);
            set argStrStart: int = br(argsBuf, s1 * 4 + 1);
            set argStrLen: int = br(argsBuf, s1 * 4 + 2);
            set argTy: int = br(argsBuf, s1 * 4 + 3);
            if (argTy == 1) {
                setRegInt(regBuf, dst, argVal);
            } else {
                set strVal: string = substring(callerPool, argStrStart, argStrStart + argStrLen);
                setRegStr(regBuf, strPool, dst, strVal);
            }
        } else if (op == 12) {
            set s1s: string = getRegStr(regBuf, strPool, s1);
            set s2s: string = getRegStr(regBuf, strPool, s2);
            setRegStr(regBuf, strPool, dst, str_concat(s1s, s2s));
        }

        ji = ji + 1;
    }

    // Handle block terminator
    if (tt == 1) { return t0; }
    else if (tt == 2) {
        set condVal: int = getRegInt(regBuf, t0);
        if (condVal != 0) { return curBlockIdx + 1; }
        else { if (t1 != 0) { return t1; } else { return curBlockIdx + 1; } }
    }
    else if (tt == 3) { return -2; }
    else { return curBlockIdx + 1; }
}

function execMirFn(mirBuf: string, progOff: int, src: string, fnOff: int,
    regBuf: string, strPool: string, argsBuf: string, callerPool: string, argCount: int): void {

    set bc: int = mFnBlockCount(mirBuf, fnOff);
    set curBlockIdx: int = 0;
    set maxIter: int = 100000;
    set iter: int = 0;
    set varMap: string = makeValBuf();
    set varSlotNext: int = 1024;
    bw(strPool, 9998, 0);

    while (curBlockIdx >= 0 && curBlockIdx < bc && iter < maxIter) {
        iter = iter + 1;
        set nextBlock: int = stepBlock(mirBuf, progOff, fnOff, src,
            regBuf, strPool, argsBuf, callerPool,
            curBlockIdx, varMap, varSlotNext, bc);
        if (nextBlock == -2) { curBlockIdx = -1; }
        else if (nextBlock == -1) { curBlockIdx = -1; }
        else { curBlockIdx = nextBlock; }
    }

    if (iter >= maxIter) {
        diagReport(5, "");
    }
}

function findFn(mirBuf: string, progOff: int, src: string, nameOff: int, nameLen: int): int {
    set fnCount: int = br(mirBuf, progOff + 1);
    set i: int = 0;
    while (i < fnCount) {
        set fnOff: int = br(mirBuf, progOff + 2 + i);
        set no: int = mFnNameOff(mirBuf, fnOff);
        set nl: int = mFnNameLen(mirBuf, fnOff);
        if (nl == nameLen) {
            set isMatch: int = 1;
            set j: int = 0;
            while (j < nl) {
                if (charCode(src, no + j) != charCode(src, nameOff + j)) { isMatch = 0; break; }
                j = j + 1;
            }
            if (isMatch == 1) { return fnOff; }
        }
        i = i + 1;
    }
    return -1;
}
