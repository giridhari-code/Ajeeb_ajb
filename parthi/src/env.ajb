// env.ajb — Function environment stubs for ParthI
// Function lookup done directly from MIR program in mir_interp.ajb
// All errors in Hinglish!

function bw(buf: string, slot: int, val: int): void { setInt(buf, slot * 8, val); }
function br(buf: string, slot: int): int { return getInt(buf, slot * 8); }
