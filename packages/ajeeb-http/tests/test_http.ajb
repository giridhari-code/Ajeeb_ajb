// ajeeb-http test suite — self-contained
// Tests HTTP request parsing, status text, and server struct

struct Route {
    method: String;
    path: String;
    handler: String;
}

struct HttpServer {
    port: Int;
    routes: Route[];
    running: Bool;
}

struct HttpRequest {
    method: String;
    path: String;
    headers: Array;
    body: String;
}

function http_new(): HttpServer {
    return HttpServer {
        port: 0,
        routes: [],
        running: false
    };
}

function http_route(server: HttpServer, method: String, path: String, handler: String) {
    set n = arr_len(server.routes);
    set route = Route {
        method: method,
        path: path,
        handler: handler
    };
    server.routes[n] = route;
}

function http_parse_request(raw: String): HttpRequest {
    set header_end = indexOf(raw, "\n\n");
    set header_section = "";
    set body = "";
    if (header_end > 0) {
        header_section = substring(raw, 0, header_end);
        set body_start = header_end + 2;
        if (body_start < len(raw)) {
            body = substring(raw, body_start, len(raw));
        }
    } else {
        header_section = raw;
    }
    set lines = split(header_section, "\n");
    set method = "";
    set path = "";
    set headers = [];
    set n = arr_len(lines);
    if (n > 0) {
        set parts = split(lines[0], " ");
        if (arr_len(parts) >= 2) {
            method = parts[0];
            path = parts[1];
        }
    }
    set j = 1;
    while (j < n) {
        headers[j - 1] = lines[j];
        j = j + 1;
    }
    return HttpRequest {
        method: method,
        path: path,
        headers: headers,
        body: body
    };
}

function http_status_text(code: Int): String {
    if (code == 200) { return "OK"; }
    if (code == 201) { return "Created"; }
    if (code == 204) { return "No Content"; }
    if (code == 301) { return "Moved Permanently"; }
    if (code == 302) { return "Found"; }
    if (code == 400) { return "Bad Request"; }
    if (code == 401) { return "Unauthorized"; }
    if (code == 403) { return "Forbidden"; }
    if (code == 404) { return "Not Found"; }
    if (code == 405) { return "Method Not Allowed"; }
    if (code == 409) { return "Conflict"; }
    if (code == 422) { return "Unprocessable Entity"; }
    if (code == 429) { return "Too Many Requests"; }
    if (code == 500) { return "Internal Server Error"; }
    if (code == 502) { return "Bad Gateway"; }
    if (code == 503) { return "Service Unavailable"; }
    return "Unknown";
}

function test_http_new() {
    set srv = http_new();
    assert_eq(srv.port, 0);
    assert_eq(arr_len(srv.routes), 0);
    assert_eq(srv.running, false);
    println("  PASS http_new");
}

function test_http_route() {
    set srv = http_new();
    http_route(srv, "GET", "/hello", "handle_hello");
    http_route(srv, "POST", "/data", "handle_data");
    assert_eq(arr_len(srv.routes), 2);
    assert_eq(srv.routes[0].method, "GET");
    assert_eq(srv.routes[0].path, "/hello");
    assert_eq(srv.routes[0].handler, "handle_hello");
    assert_eq(srv.routes[1].method, "POST");
    println("  PASS http_route");
}

function test_parse_get_request() {
    set raw = "GET /api/users HTTP/1.1\nHost: example.com\nAccept: */*\n\n";
    set req = http_parse_request(raw);
    assert_eq(req.method, "GET");
    assert_eq(req.path, "/api/users");
    assert_eq(arr_len(req.headers), 2);
    assert_eq(req.headers[0], "Host: example.com");
    assert_eq(req.body, "");
    println("  PASS parse_get_request: " + req.method + " " + req.path);
}

function test_parse_post_request() {
    set raw = "POST /data HTTP/1.1\nHost: example.com\nContent-Type: application/json\n\n{\"key\":\"value\"}";
    set req = http_parse_request(raw);
    assert_eq(req.method, "POST");
    assert_eq(req.path, "/data");
    assert_eq(arr_len(req.headers), 2);
    assert_eq(req.headers[1], "Content-Type: application/json");
    assert_eq(req.body, "{\"key\":\"value\"}");
    println("  PASS parse_post_request: body=" + req.body);
}

function test_parse_empty_body() {
    set raw = "GET / HTTP/1.1\n\n";
    set req = http_parse_request(raw);
    assert_eq(req.method, "GET");
    assert_eq(req.body, "");
    println("  PASS parse_empty_body");
}

function test_parse_no_headers() {
    set raw = "GET /test HTTP/1.1\n\nbody";
    set req = http_parse_request(raw);
    assert_eq(req.method, "GET");
    assert_eq(req.path, "/test");
    assert_eq(arr_len(req.headers), 0);
    assert_eq(req.body, "body");
    println("  PASS parse_no_headers");
}

function test_status_text() {
    assert_eq(http_status_text(200), "OK");
    assert_eq(http_status_text(404), "Not Found");
    assert_eq(http_status_text(500), "Internal Server Error");
    assert_eq(http_status_text(418), "Unknown");
    assert_eq(http_status_text(201), "Created");
    assert_eq(http_status_text(301), "Moved Permanently");
    assert_eq(http_status_text(403), "Forbidden");
    assert_eq(http_status_text(503), "Service Unavailable");
    println("  PASS status_text");
}

function main() {
    println("=== ajeeb-http tests ===");
    test_http_new();
    test_http_route();
    test_parse_get_request();
    test_parse_post_request();
    test_parse_empty_body();
    test_parse_no_headers();
    test_status_text();
    println("=== All ajeeb-http tests PASS ===");
}
