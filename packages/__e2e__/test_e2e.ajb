// End-to-end test: Full API server stack
//
// Exercises: built-in functions (TCP, JSON, string ops),
// HTTP request parsing, JSON response building, and connection lifecycle.
//
// This simulates what the Parth package system produces: all functions
// from all dependencies in a single concatenated file.

// ── HTTP Request Parsing ──────────────────────────────────────────

struct HttpRequest {
    method: String;
    path: String;
    headers: Array;
    body: String;
}

function http_parse_request(raw: String): HttpRequest {
    let header_end = indexOf(raw, "\n\n");
    let header_section = "";
    let body = "";
    if (header_end > 0) {
        header_section = substring(raw, 0, header_end);
        let body_start = header_end + 2;
        if (body_start < len(raw)) {
            body = substring(raw, body_start, len(raw));
        }
    } else {
        header_section = raw;
    }
    let lines = split(header_section, "\n");
    let method = "";
    let path = "";
    let headers = [];
    let n = arr_len(lines);
    if (n > 0) {
        let parts = split(lines[0], " ");
        if (arr_len(parts) >= 2) {
            method = parts[0];
            path = parts[1];
        }
    }
    let j = 1;
    while (j < n) {
        headers[j - 1] = lines[j];
        j = j + 1;
    }
    return HttpRequest {
        method: method,
        path: path,
        headers: headers,
        body: body
    };
}

// ── HTTP Response Building ────────────────────────────────────────

function http_status_text(code: Int): String {
    if (code == 200) { return "OK"; }
    if (code == 201) { return "Created"; }
    if (code == 400) { return "Bad Request"; }
    if (code == 404) { return "Not Found"; }
    if (code == 405) { return "Method Not Allowed"; }
    if (code == 500) { return "Internal Server Error"; }
    return "Unknown";
}

function build_http_response(status: Int, content_type: String, body: String): String {
    let status_line = "HTTP/1.1 " + itoa(status) + " " + http_status_text(status) + "\n";
    let headers = "Content-Type: " + content_type + "\n";
    let content_len = "Content-Length: " + itoa(len(body)) + "\n";
    return status_line + headers + content_len + "Connection: close\n\n" + body;
}

// ── Route Handler ─────────────────────────────────────────────────

function handle_home(method: String, path: String, body: String): Array {
    let resp_body = "{\"message\":\"Welcome to Ajeeb API!\",\"version\":\"1.0\"}";
    return [200, resp_body];
}

function handle_users(method: String, path: String, body: String): Array {
    if (method == "GET") {
        let resp_body = "{\"users\":[{\"id\":\"1\",\"name\":\"Alice\"},{\"id\":\"2\",\"name\":\"Bob\"}],\"count\":2}";
        return [200, resp_body];
    }
    if (method == "POST") {
        let resp_body = "{\"status\":\"created\",\"received\":" + body + "}";
        return [201, resp_body];
    }
    return [405, "{\"error\":\"Method not allowed\"}"];
}

function handle_echo(method: String, path: String, body: String): Array {
    return [200, body];
}

// ── Router + Dispatch ─────────────────────────────────────────────

struct Route {
    method: String;
    path: String;
    handler: String;
}

let routes = [];

function register_route(method: String, path: String, handler: String) {
    let n = arr_len(routes);
    routes[n] = Route { method: method, path: path, handler: handler };
}

function dispatch(method: String, path: String, body: String): Array {
    let i = 0;
    let n = arr_len(routes);
    while (i < n) {
        let r = routes[i];
        if (r.method == method && r.path == path) {
            if (r.handler == "handle_home") {
                return handle_home(method, path, body);
            }
            if (r.handler == "handle_users") {
                return handle_users(method, path, body);
            }
            if (r.handler == "handle_echo") {
                return handle_echo(method, path, body);
            }
        }
        i = i + 1;
    }
    let resp_body = "{\"error\":\"Not Found\",\"path\":\"" + path + "\"}";
    return [404, resp_body];
}

// ── Server Loop ───────────────────────────────────────────────────

function handle_client(client_fd: Int) {
    let raw = tcp_read(client_fd, 8192);
    if (len(raw) == 0) {
        return;
    }
    let req = http_parse_request(raw);
    let response = dispatch(req.method, req.path, req.body);
    let http_resp = build_http_response(response[0], "application/json", response[1]);
    tcp_write(client_fd, http_resp);
}

function start_server(port: Int) {
    println("Starting server on port " + itoa(port) + "...");
    let listen_fd = tcp_listen(port);
    if (listen_fd == 0) {
        println("ERROR: Failed to listen on port " + itoa(port));
        return;
    }
    println("Server listening. Use curl to test:");
    println("  curl http://localhost:" + itoa(port) + "/");
    println("  curl http://localhost:" + itoa(port) + "/users");
    println("  curl -X POST -d '{\"name\":\"Charlie\"}' http://localhost:" + itoa(port) + "/users");
    println("  curl http://localhost:" + itoa(port) + "/echo/hello");

    let running = true;
    while (running) {
        let client_fd = tcp_accept(listen_fd);
        if (client_fd > 0) {
            handle_client(client_fd);
            tcp_close(client_fd);
        }
    }
    println("Server stopped.");
    tcp_close(listen_fd);
}

// ── Tests ─────────────────────────────────────────────────────────

function test_http_parse() {
    let raw = "GET /users HTTP/1.1\nHost: localhost\n\n";
    let req = http_parse_request(raw);
    assert_eq(req.method, "GET");
    assert_eq(req.path, "/users");
    assert_eq(req.body, "");

    let raw2 = "POST /api/data HTTP/1.1\nContent-Type: application/json\n\n{\"key\":\"val\"}";
    let req2 = http_parse_request(raw2);
    assert_eq(req2.method, "POST");
    assert_eq(req2.path, "/api/data");
    let data_idx = indexOf(req2.body, "\"key\"");
    assert_neq(data_idx, -1);

    let raw3 = "GET / HTTP/1.1\n\n";
    let req3 = http_parse_request(raw3);
    assert_eq(req3.method, "GET");
    assert_eq(arr_len(req3.headers), 0);

    println("  PASS test_http_parse");
}

function test_routing() {
    register_route("GET", "/", "handle_home");
    register_route("GET", "/users", "handle_users");
    register_route("POST", "/users", "handle_users");
    register_route("GET", "/echo", "handle_echo");

    let r1 = dispatch("GET", "/", "");
    assert_eq(r1[0], 200);
    let r1_body = r1[1];
    let msg_idx = indexOf(r1_body, "Welcome");
    assert_neq(msg_idx, -1);

    let r2 = dispatch("GET", "/users", "");
    assert_eq(r2[0], 200);
    let r2_body = r2[1];
    let alice_idx = indexOf(r2_body, "Alice");
    assert_neq(alice_idx, -1);

    let r3 = dispatch("POST", "/users", "{\"name\":\"Test\"}");
    assert_eq(r3[0], 201);
    let r3_body = r3[1];
    let created_idx = indexOf(r3_body, "created");
    assert_neq(created_idx, -1);

    let r4 = dispatch("DELETE", "/nothing", "");
    assert_eq(r4[0], 404);
    let r4_body = r4[1];
    let nf_idx = indexOf(r4_body, "Not Found");
    assert_neq(nf_idx, -1);

    println("  PASS test_routing");
}

function test_build_response() {
    let resp = build_http_response(200, "application/json", "{\"status\":\"ok\"}");
    let http_idx = indexOf(resp, "HTTP/1.1 200 OK");
    let ct_idx = indexOf(resp, "Content-Type: application/json");
    let cl_idx = indexOf(resp, "Content-Length:");
    assert_neq(http_idx, -1);
    assert_neq(ct_idx, -1);
    assert_neq(cl_idx, -1);
    println("  PASS build_http_response");
}

function test_status_codes() {
    assert_eq(http_status_text(200), "OK");
    assert_eq(http_status_text(404), "Not Found");
    assert_eq(http_status_text(500), "Internal Server Error");
    assert_eq(http_status_text(418), "Unknown");
    assert_eq(http_status_text(405), "Method Not Allowed");
    println("  PASS test_status_codes");
}

function test_http_response_body() {
    let resp = build_http_response(404, "text/plain", "Not Found");
    let body_start = indexOf(resp, "\n\n");
    let body = "";
    if (body_start > 0) {
        body = substring(resp, body_start + 2, len(resp));
    }
    assert_eq(body, "Not Found");
    println("  PASS test_http_response_body");
}

// ── Main ──────────────────────────────────────────────────────────

function main() {
    println("");
    println("╔══════════════════════════════════════════╗");
    println("║   Ajeeb End-to-End Test Suite            ║");
    println("╚══════════════════════════════════════════╝");
    println("");

    println("=== Test 1: HTTP Request Parsing ===");
    test_http_parse();

    println("");
    println("=== Test 2: Routing ===");
    test_routing();

    println("");
    println("=== Test 3: HTTP Response Building ===");
    test_build_response();

    println("");
    println("=== Test 4: Status Codes ===");
    test_status_codes();

    println("");
    println("=== Test 5: Response Body Extraction ===");
    test_http_response_body();

    println("");
    println("=== All end-to-end tests PASS ===");
    println("");

    // Uncomment to run the actual server:
    // start_server(8080);
}
