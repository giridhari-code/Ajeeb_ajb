intptr_t tokenPrec(intptr_t buf) {
    intptr_t tt = tokType(buf);
    if (tt == 23) {
    return 1;
    }
    if (tt == 22) {
    return 2;
    }
    if (tt == 16 || tt == 17) {
    return 3;
    }
    if (tt == 18 || tt == 19 || tt == 20 || tt == 21) {
    return 4;
    }
    if (tt == 11 || tt == 12 || tt == 28) {
    return 5;
    }
    if (tt == 13 || tt == 14 || tt == 29) {
    return 6;
    }
    return 0;
}

intptr_t parseBinary(intptr_t src, intptr_t buf, intptr_t minPrec) {
    intptr_t left = parseAtom(src, buf);
    while (tokenPrec(buf) >= minPrec) {
    intptr_t tt = tokType(buf);
    intptr_t prec = tokenPrec(buf);
    if (tt == 29) {
    nextTok(src, buf);
    intptr_t right = parseBinary(src, buf, prec + 1);
    left = hBinop(buf, left, 16, right);
    }
    else {
    intptr_t opCode = 0;
    if (tt == 11) {
    opCode = 1;
    }
    else if (tt == 12) {
    opCode = 2;
    }
    else if (tt == 13) {
    opCode = 3;
    }
    else if (tt == 14) {
    opCode = 4;
    }
    else if (tt == 28) {
    opCode = 15;
    }
    else if (tt == 16) {
    opCode = 5;
    }
    else if (tt == 17) {
    opCode = 6;
    }
    else if (tt == 18) {
    opCode = 7;
    }
    else if (tt == 19) {
    opCode = 8;
    }
    else if (tt == 20) {
    opCode = 9;
    }
    else if (tt == 21) {
    opCode = 10;
    }
    else if (tt == 22) {
    opCode = 11;
    }
    else if (tt == 23) {
    opCode = 12;
    }
    nextTok(src, buf);
    intptr_t right = parseBinary(src, buf, prec + 1);
    left = hBinop(buf, left, opCode, right);
    }
    }
    return left;
}

intptr_t parseExpr(intptr_t src, intptr_t buf) {
    intptr_t left = parseBinary(src, buf, 1);
    intptr_t tt = tokType(buf);
    if (tt == 15) {
    intptr_t lt = br(buf, left);
    if (lt == 14) {
    intptr_t no = br(buf, left + 1);
    intptr_t nl = br(buf, left + 2);
    nextTok(src, buf);
    intptr_t v = parseExpr(src, buf);
    return hAssign(buf, no, nl, v);
    }
    }
    if (tt == 32 || tt == 33 || tt == 34 || tt == 35) {
    intptr_t lt = br(buf, left);
    if (lt == 14) {
    intptr_t no = br(buf, left + 1);
    intptr_t nl = br(buf, left + 2);
    intptr_t binOp = 1;
    if (tt == 33) {
    binOp = 2;
    }
    else if (tt == 34) {
    binOp = 3;
    }
    else if (tt == 35) {
    binOp = 4;
    }
    nextTok(src, buf);
    intptr_t v = parseExpr(src, buf);
    return hAssign(buf, no, nl, hBinop(buf, hIdent(buf, no, nl), binOp, v));
    }
    }
    return left;
}

