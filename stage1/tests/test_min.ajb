function main(): int {
    set buf: string = getStateBuf();
    set i: int = 0;
    while (i < 128) { setInt(buf, i * 8, 0); i = i + 1; }
    set src: string = readFile("tests/test_simple.ajb");
    set out: string = "build/debug_min.txt";
    writeFile(out, "");
    set pos: int = rdPos(buf);
    set c: int = chr(src, pos);
    writeAppend(out, "Initial pos=");
    writeAppend(out, itoa(pos));
    writeAppend(out, " c=");
    writeAppend(out, itoa(c));
    writeAppend(out, "\n");
    pos = 55;
    wrPos(buf, pos);
    c = chr(src, pos);
    writeAppend(out, "After set pos=55 c=");
    writeAppend(out, itoa(c));
    writeAppend(out, "\n");
    set tn: int = isAlpha(c);
    writeAppend(out, "isAlpha=");
    writeAppend(out, itoa(tn));
    writeAppend(out, "\n");
    return 0;
}
