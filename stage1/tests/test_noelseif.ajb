function isSpace(c: int): int { if (c == 32 || c == 9 || c == 10 || c == 13) { return 1; } return 0; }

function main(): int {
    set out: string = "build/debug_noelseif.txt";
    writeFile(out, "");
    set pos: int = 0;
    set go: int = 1;
    while (go == 1) {
        writeAppend(out, "pos=");
        writeAppend(out, itoa(pos));
        writeAppend(out, "\n");
        if (pos == 0) { pos = pos + 2; }
        else if (pos == 2) { pos = pos + 1; }
        else if (pos == 3) { pos = pos + 1; }
        else { go = 0; }
    }
    writeAppend(out, "FINAL pos=");
    writeAppend(out, itoa(pos));
    writeAppend(out, "\n");
    return 0;
}
