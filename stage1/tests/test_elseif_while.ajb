function main(): int {
    set x: int = 0;
    set go: int = 1;
    while (go == 1) {
        if (x == 0) { x = x + 1; }
        else if (x == 1) { x = x + 1; }
        else if (x == 2) { x = x + 1; }
        else { go = 0; }
    }
    set out: string = "build/debug_elseif_while.txt";
    writeFile(out, "");
    writeAppend(out, "x=");
    writeAppend(out, itoa(x));
    writeAppend(out, "\n");
    return 0;
}
