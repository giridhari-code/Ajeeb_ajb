function main(): int {
    set out: string = "build/debug_nestedwhile2.txt";
    writeFile(out, "");
    set x: int = 5;
    while (x > 0) {
        if (x == 5) {
            writeAppend(out, "FIVE\n");
        }
        else if (x == 3) {
            set j: int = 0;
            while (j < 3) { writeAppend(out, "J\n"); j = j + 1; }
        }
        else {
            writeAppend(out, "OTHER\n");
        }
        x = x - 1;
    }
    return 0;
}
