function doStuff(pos: int): int {
    set go: int = 1;
    while (go == 1) {
        if (pos == 0) {
            set inner_pos: int = 5;
            while (inner_pos < 8) { inner_pos = inner_pos + 1; }
        }
        pos = pos + 1;
        if (pos > 3) { go = 0; }
    }
    return pos;
}

function main(): int {
    set out: string = "build/debug_nested_func.txt";
    writeFile(out, "");
    set result: int = doStuff(0);
    writeAppend(out, "result=");
    writeAppend(out, itoa(result));
    writeAppend(out, "\n");
    return 0;
}
