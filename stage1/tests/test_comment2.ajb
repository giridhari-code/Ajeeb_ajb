function isSpace(c: int): int { if (c == 32 || c == 9 || c == 10 || c == 13) { return 1; } return 0; }
function chr(src: int, i: int): int { return charCode(src, i); }
function main(): int {
    set buf: string = getStateBuf();
    set inPath: string = readArg(1);
    set src: string = readFile(inPath);
    set out: string = "build/debug_comment.txt";
    writeFile(out, "");
    set pos: int = 0;
    set go: int = 1;
    while (go == 1) {
        set c: int = chr(src, pos);
        writeAppend(out, "loop pos=");
        writeAppend(out, itoa(pos));
        writeAppend(out, " c=");
        writeAppend(out, itoa(c));
        writeAppend(out, "\n");
        if (isSpace(c) == 1) { pos = pos + 1; }
        else if (c == 47 && chr(src, pos+1) == 47) {
            writeAppend(out, "found //\n");
            pos = pos + 2;
            while (chr(src, pos) != 10 && chr(src, pos) != 0) { pos = pos + 1; }
            writeAppend(out, "end comment pos=");
            writeAppend(out, itoa(pos));
            writeAppend(out, " c=");
            writeAppend(out, itoa(chr(src, pos)));
            writeAppend(out, "\n");
        }
        else { go = 0; }
    }
    writeAppend(out, "final pos=");
    writeAppend(out, itoa(pos));
    writeAppend(out, " c=");
    writeAppend(out, itoa(chr(src, pos)));
    writeAppend(out, "\n");
    return 0;
}
