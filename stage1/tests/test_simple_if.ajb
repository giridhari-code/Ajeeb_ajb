function main(): int {
    set pos: int = 0;
    set go: int = 1;
    while (go == 1) {
        if (pos == 0) { pos = pos + 2; }
        else if (pos == 2) { pos = pos + 1; }
        else if (pos == 3) { pos = pos + 1; }
        else { go = 0; }
    }
    set out: string = "build/debug_simple_if.txt";
    writeFile(out, "");
    writeAppend(out, "FINAL pos=");
    writeAppend(out, itoa(pos));
    writeAppend(out, "\n");
    return 0;
}
