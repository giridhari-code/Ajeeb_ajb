function main(): int {
    set path: string = readArg(1);
    set src: string = readFile(path);
    set out: string = "build/debug_read.txt";
    writeFile(out, "");
    set i: int = 0;
    while (i < 20) {
        set c: int = charCode(src, i);
        writeAppend(out, itoa(c) + " ");
        i = i + 1;
    }
    writeAppend(out, "\nlen=" + itoa(len(src)) + "\n");
    return 0;
}
