function isDigit(c: int): int { if (c >= 48 && c <= 57) { return 1; } return 0; }
function isAlpha(c: int): int {
    if (c >= 65 && c <= 90) { return 1; }
    if (c >= 97 && c <= 122) { return 1; }
    if (c == 95) { return 1; }
    return 0;
}
function isAlphaNum(c: int): int { if (isDigit(c) == 1) { return 1; } if (isAlpha(c) == 1) { return 1; } return 0; }
function isSpace(c: int): int { if (c == 32 || c == 9 || c == 10 || c == 13) { return 1; } return 0; }
function chr(src: int, i: int): int { return charCode(src, i); }

function main(): int {
    set src: string = "Hello // comment\nWorld";
    set out: string = "build/debug_trace.txt";
    writeFile(out, "");
    set pos: int = 0;
    set go: int = 1;
    while (go == 1) {
        set c: int = chr(src, pos);
        if (isSpace(c) == 1) {
            writeAppend(out, "SPACE pos=");
            writeAppend(out, itoa(pos));
            writeAppend(out, " c=");
            writeAppend(out, itoa(c));
            writeAppend(out, "\n");
            pos = pos + 1;
        }
        else if (c == 47 && chr(src, pos + 1) == 47) {
            writeAppend(out, "LINE_COMMENT pos=");
            writeAppend(out, itoa(pos));
            writeAppend(out, "\n");
            pos = pos + 2;
            while (chr(src, pos) != 10 && chr(src, pos) != 0) { pos = pos + 1; }
            writeAppend(out, "COMMENT_END pos=");
            writeAppend(out, itoa(pos));
            writeAppend(out, "\n");
        }
        else {
            writeAppend(out, "STOP pos=");
            writeAppend(out, itoa(pos));
            writeAppend(out, " c=");
            writeAppend(out, itoa(c));
            writeAppend(out, "\n");
            go = 0;
        }
    }
    writeAppend(out, "FINAL pos=");
    writeAppend(out, itoa(pos));
    writeAppend(out, " c=");
    writeAppend(out, itoa(chr(src, pos)));
    writeAppend(out, "\n");
    return 0;
}
