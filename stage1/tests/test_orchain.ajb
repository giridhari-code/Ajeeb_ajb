function main(): int {
    set out: string = "build/debug_orchain.txt";
    writeFile(out, "");
    set x: int = 5;
    while (x > 0) {
        if (x == 5 || x == 4) {
            writeAppend(out, "FIVE_OR_FOUR\n");
        }
        else if (x == 3) {
            writeAppend(out, "THREE\n");
        }
        else {
            writeAppend(out, "OTHER\n");
        }
        x = x - 1;
    }
    return 0;
}
