function main(): int {
    set src: string = readFile("tests/test_simple.ajb");
    set out: string = "build/debug_readtr2.txt";
    writeFile(out, "");
    set pos: int = 0;
    set go: int = 1;
    set iter: int = 0;
    while (go == 1) {
        set c: int = charCode(src, pos);
        writeAppend(out, "iter=");
        writeAppend(out, itoa(iter));
        writeAppend(out, " pos=");
        writeAppend(out, itoa(pos));
        writeAppend(out, " c=");
        writeAppend(out, itoa(c));
        writeAppend(out, "\n");
        if (c == 32 || c == 9 || c == 10 || c == 13) {
            pos = pos + 1;
        }
        else if (c == 47 && charCode(src, pos + 1) == 47) {
            pos = pos + 2;
            while (charCode(src, pos) != 10 && charCode(src, pos) != 0) { pos = pos + 1; }
        }
        else {
            writeAppend(out, "STOPPED at ");
            writeAppend(out, itoa(pos));
            writeAppend(out, "\n");
            go = 0;
        }
        iter = iter + 1;
        if (iter > 25) { go = 0; }
    }
    writeAppend(out, "FINAL pos=");
    writeAppend(out, itoa(pos));
    writeAppend(out, "\n");
    return 0;
}
