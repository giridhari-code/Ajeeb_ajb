function isSpace(c: int): int { if (c == 32 || c == 9 || c == 10 || c == 13) { return 1; } return 0; }
function chr(src: int, i: int): int { return charCode(src, i); }

function main(): int {
    set buf: string = getStateBuf();
    set inPath: string = readArg(1);
    set src: string = readFile(inPath);
    set out: string = "build/debug_skipws.txt";
    writeFile(out, "");

    set pos: int = 0;
    set go: int = 1;
    set inLine: int = 0;
    set inBlock: int = 0;
    while (go == 1) {
        set c: int = chr(src, pos);
        writeAppend(out, "pos=");
        writeAppend(out, itoa(pos));
        writeAppend(out, " c=");
        writeAppend(out, itoa(c));
        writeAppend(out, " inLine=");
        writeAppend(out, itoa(inLine));
        writeAppend(out, " inBlock=");
        writeAppend(out, itoa(inBlock));
        writeAppend(out, "\n");
        if (inLine == 1) {
            if (c == 10 || c == 0) { inLine = 0; }
            else { pos = pos + 1; }
        }
        else if (inBlock == 1) {
            if (c == 42 && chr(src, pos+1) == 47) { inBlock = 0; pos = pos + 2; }
            else { pos = pos + 1; }
        }
        else if (isSpace(c) == 1) { pos = pos + 1; }
        else if (c == 47 && chr(src, pos+1) == 47) { pos = pos + 2; inLine = 1; }
        else if (c == 47 && chr(src, pos+1) == 42) { pos = pos + 2; inBlock = 1; }
        else { go = 0; }
    }
    writeAppend(out, "FINAL pos=");
    writeAppend(out, itoa(pos));
    writeAppend(out, " c=");
    writeAppend(out, itoa(chr(src, pos)));
    writeAppend(out, "\n");
    return 0;
}
