function testE2ETree(): int {
    set passed: int = 0;
    set failed: int = 0;

    // Setup test packages
    mkdir("packages");
    mkdir("packages/alpha");
    mkdir("packages/beta");
    mkdir("packages/charlie");

    writeFile("packages/alpha/parth.das", "[package]\nname = \"alpha\"\nversion = \"1.0.0\"\n\n[dependencies]\nbeta = \"^1.0.0\"\ncharlie = \"^2.0.0\"\n");
    writeFile("packages/beta/parth.das", "[package]\nname = \"beta\"\nversion = \"1.2.0\"\n\n[dependencies]\n");
    writeFile("packages/charlie/parth.das", "[package]\nname = \"charlie\"\nversion = \"2.1.0\"\n\n[dependencies]\n");

    // Create root project with alpha dep
    writeFile("parth.das", "[package]\nname = \"treetest\"\nversion = \"0.1.0\"\n\n[dependencies]\nalpha = \"^1.0.0\"\n\n[compiler]\ntarget = \"native\"\noutput = \"build/\"\nruntime = \"runtime/ajeeb_runtime.c\"\n");

    // Test tree display
    set r: int = dependencyTree();
    if (r == 0) {
        println("  ✓ Tree display succeeded"); passed = passed + 1;
    } else { println("  ✗ Tree display failed"); failed = failed + 1; }

    // Test resolveAll
    set buf: string = getStateBuf();
    set r2: int = parseDasConfig("parth.das");
    set src: string = readFile("parth.das");
    set r3: int = resolveAll(buf, src);
    if (r3 == 0) {
        println("  ✓ resolveAll succeeded"); passed = passed + 1;
    } else { println("  ✗ resolveAll failed"); failed = failed + 1; }

    // Test cycle detection in tree
    writeFile("packages/beta/parth.das", "[package]\nname = \"beta\"\nversion = \"1.2.0\"\n\n[dependencies]\nalpha = \"^1.0.0\"\n");
    set r4: int = dependencyTree();
    if (r4 == 0) {
        println("  ✓ Cycle in tree handled"); passed = passed + 1;
    } else { println("  ✗ Cycle in tree failed"); failed = failed + 1; }

    // Test conflict detection (both exact, incompatible versions)
    writeFile("packages/beta/parth.das", "[package]\nname = \"beta\"\nversion = \"1.2.0\"\n\n[dependencies]\ncharlie = \"4.0.0\"\n");
    writeFile("parth.das", "[package]\nname = \"treetest\"\nversion = \"0.1.0\"\n\n[dependencies]\nalpha = \"^1.0.0\"\ncharlie = \"3.0.0\"\n\n[compiler]\ntarget = \"native\"\noutput = \"build/\"\nruntime = \"runtime/ajeeb_runtime.c\"\n");
    set buf2: string = getStateBuf();
    set r5: int = parseDasConfig("parth.das");
    set src2: string = readFile("parth.das");
    set r6: int = resolveAll(buf2, src2);
    // alpha→beta→charlie@3.0.0 conflicts with root charlie@^2.0.0
    if (r6 == 1) {
        println("  ✓ Conflict detected in resolveAll"); passed = passed + 1;
    } else { println("  ✗ Conflict not detected"); failed = failed + 1; }

    // Cleanup
    exec("rm -rf packages");
    exec("rm -f parth.das");

    set total: string = str_concat(itoa(passed), " passed, ");
    total = str_concat(total, str_concat(itoa(failed), " failed"));
    println(total);
    if (failed > 0) { return 1; }
    return 0;
}

function testSemver(): int {
    set passed: int = 0;
    set failed: int = 0;
    set buf: string = getStateBuf();

    // Helper: assert parseSemver
    // Test 1: parseSemver("1.2.3")
    set r: int = parseSemver("1.2.3");
    if (r == 0 && br(buf, 500) == 1 && br(buf, 501) == 2 && br(buf, 502) == 3) {
        println("✓ parseSemver(\"1.2.3\") => 1.2.3");
        passed = passed + 1;
    } else {
        println("✗ parseSemver(\"1.2.3\") failed");
        failed = failed + 1;
    }

    // Test 2: parseSemver("0.1.0")
    r = parseSemver("0.1.0");
    if (r == 0 && br(buf, 500) == 0 && br(buf, 501) == 1 && br(buf, 502) == 0) {
        println("✓ parseSemver(\"0.1.0\") => 0.1.0");
        passed = passed + 1;
    } else {
        println("✗ parseSemver(\"0.1.0\") failed");
        failed = failed + 1;
    }

    // Test 3: compareVersions(1.2.3, 1.2.3) == 0
    parseSemver("1.2.3");
    set aOff: int = 500;
    parseSemver("1.2.3");
    set bOff: int = 500;
    // Need separate slots — re-parse into different positions
    parseSemver("1.2.3");
    bw(buf, 510, br(buf, 500));
    bw(buf, 511, br(buf, 501));
    bw(buf, 512, br(buf, 502));
    parseSemver("1.2.3");
    bw(buf, 520, br(buf, 500));
    bw(buf, 521, br(buf, 501));
    bw(buf, 522, br(buf, 502));
    set cmp: int = compareVersions(510, 520);
    if (cmp == 0) {
        println("✓ compareVersions(1.2.3, 1.2.3) == 0");
        passed = passed + 1;
    } else {
        println("✗ compareVersions(1.2.3, 1.2.3) expected 0");
        failed = failed + 1;
    }

    // Test 4: compareVersions(1.2.4, 1.2.3) == 1
    parseSemver("1.2.4");
    bw(buf, 510, br(buf, 500));
    bw(buf, 511, br(buf, 501));
    bw(buf, 512, br(buf, 502));
    parseSemver("1.2.3");
    bw(buf, 520, br(buf, 500));
    bw(buf, 521, br(buf, 501));
    bw(buf, 522, br(buf, 502));
    cmp = compareVersions(510, 520);
    if (cmp == 1) {
        println("✓ compareVersions(1.2.4, 1.2.3) == 1");
        passed = passed + 1;
    } else {
        println("✗ compareVersions(1.2.4, 1.2.3) expected 1");
        failed = failed + 1;
    }

    // Test 5: compareVersions(1.2.3, 1.2.4) == -1
    cmp = compareVersions(520, 510);
    if (cmp == -1) {
        println("✓ compareVersions(1.2.3, 1.2.4) == -1");
        passed = passed + 1;
    } else {
        println("✗ compareVersions(1.2.3, 1.2.4) expected -1");
        failed = failed + 1;
    }

    // Test 6: exact match — 1.2.3 matches 1.2.3
    parseConstraint("1.2.3");
    parseSemver("1.2.3");
    if (matchesConstraint(500, 600) == 1) {
        println("✓ exact 1.2.3 matches 1.2.3");
        passed = passed + 1;
    } else {
        println("✗ exact 1.2.3 should match 1.2.3");
        failed = failed + 1;
    }

    // Test 7: exact mismatch — 1.2.3 rejects 1.2.4
    parseSemver("1.2.4");
    if (matchesConstraint(500, 600) == 0) {
        println("✓ exact 1.2.3 rejects 1.2.4");
        passed = passed + 1;
    } else {
        println("✗ exact 1.2.3 should reject 1.2.4");
        failed = failed + 1;
    }

    // Test 8: caret — ^1.2.3 matches 1.5.0
    parseConstraint("^1.2.3");
    parseSemver("1.5.0");
    if (matchesConstraint(500, 600) == 1) {
        println("✓ ^1.2.3 matches 1.5.0");
        passed = passed + 1;
    } else {
        println("✗ ^1.2.3 should match 1.5.0");
        failed = failed + 1;
    }

    // Test 9: caret — ^1.2.3 rejects 2.0.0
    parseSemver("2.0.0");
    if (matchesConstraint(500, 600) == 0) {
        println("✓ ^1.2.3 rejects 2.0.0");
        passed = passed + 1;
    } else {
        println("✗ ^1.2.3 should reject 2.0.0");
        failed = failed + 1;
    }

    // Test 10: caret 0.x — ^0.2.3 rejects 0.3.0
    parseConstraint("^0.2.3");
    parseSemver("0.3.0");
    if (matchesConstraint(500, 600) == 0) {
        println("✓ ^0.2.3 rejects 0.3.0");
        passed = passed + 1;
    } else {
        println("✗ ^0.2.3 should reject 0.3.0");
        failed = failed + 1;
    }

    // Test 11: tilde — ~1.2.3 matches 1.2.9
    parseConstraint("~1.2.3");
    parseSemver("1.2.9");
    if (matchesConstraint(500, 600) == 1) {
        println("✓ ~1.2.3 matches 1.2.9");
        passed = passed + 1;
    } else {
        println("✗ ~1.2.3 should match 1.2.9");
        failed = failed + 1;
    }

    // Test 12: tilde — ~1.2.3 rejects 1.3.0
    parseSemver("1.3.0");
    if (matchesConstraint(500, 600) == 0) {
        println("✓ ~1.2.3 rejects 1.3.0");
        passed = passed + 1;
    } else {
        println("✗ ~1.2.3 should reject 1.3.0");
        failed = failed + 1;
    }

    // Test 13: gte — >=1.2.3 matches 1.2.3
    parseConstraint(">=1.2.3");
    parseSemver("1.2.3");
    if (matchesConstraint(500, 600) == 1) {
        println("✓ >=1.2.3 matches 1.2.3");
        passed = passed + 1;
    } else {
        println("✗ >=1.2.3 should match 1.2.3");
        failed = failed + 1;
    }

    // Test 14: gte — >=1.2.3 matches 2.0.0
    parseSemver("2.0.0");
    if (matchesConstraint(500, 600) == 1) {
        println("✓ >=1.2.3 matches 2.0.0");
        passed = passed + 1;
    } else {
        println("✗ >=1.2.3 should match 2.0.0");
        failed = failed + 1;
    }

    // Test 15: gte — >=1.2.3 rejects 1.2.2
    parseSemver("1.2.2");
    if (matchesConstraint(500, 600) == 0) {
        println("✓ >=1.2.3 rejects 1.2.2");
        passed = passed + 1;
    } else {
        println("✗ >=1.2.3 should reject 1.2.2");
        failed = failed + 1;
    }

    // Test 16: wildcard — * matches everything
    parseConstraint("*");
    parseSemver("9.9.9");
    if (matchesConstraint(500, 600) == 1) {
        println("✓ * matches 9.9.9");
        passed = passed + 1;
    } else {
        println("✗ * should match 9.9.9");
        failed = failed + 1;
    }

    // Summary
    println("");
    set total: string = str_concat(itoa(passed), " passed, ");
    total = str_concat(total, str_concat(itoa(failed), " failed"));
    println(total);
    if (failed > 0) { return 1; }
    return 0;
}

function testTree(): int {
    set passed: int = 0;
    set failed: int = 0;

    // Setup: create test packages with transitive deps
    mkdir("packages");
    mkdir("packages/foo");
    mkdir("packages/bar");
    mkdir("packages/baz");
    mkdir("packages/shared");

    // foo depends on bar
    writeFile("packages/foo/parth.das", "[package]\nname = \"foo\"\nversion = \"1.0.0\"\n\n[dependencies]\nbar = \"^2.0.0\"\n");

    // bar depends on shared
    writeFile("packages/bar/parth.das", "[package]\nname = \"bar\"\nversion = \"2.1.0\"\n\n[dependencies]\nshared = \"~1.0.0\"\n");

    // baz depends on shared
    writeFile("packages/baz/parth.das", "[package]\nname = \"baz\"\nversion = \"1.5.0\"\n\n[dependencies]\nshared = \">=1.0.0\"\n");

    // shared has no deps
    writeFile("packages/shared/parth.das", "[package]\nname = \"shared\"\nversion = \"1.0.0\"\n\n[dependencies]\n");

    // Test 1: tree with linear chain (foo → bar → shared)
    println("=== Test 1: Linear chain ===");
    writeFile("parth.das", "[package]\nname = \"testapp\"\nversion = \"0.1.0\"\n\n[dependencies]\nfoo = \"^1.0.0\"\n\n[compiler]\ntarget = \"native\"\noutput = \"build/\"\nruntime = \"runtime/ajeeb_runtime.c\"\n");
    set buf: string = getStateBuf();
    set r: int = parseDasConfig("parth.das");
    if (r == 0) {
        set src: string = readFile("parth.das");
        set projName: string = getConfigName(buf, src);
        if (strcmp_ajeeb(projName, "testapp") == 0) {
            println("✓ Project name parsed correctly");
            passed = passed + 1;
        } else {
            println("✗ Project name parse failed");
            failed = failed + 1;
        }
        // Check dep count
        set dc: int = getDepCount(buf);
        if (dc == 1) {
            println("✓ Root dep count = 1");
            passed = passed + 1;
        } else {
            println("✗ Root dep count expected 1");
            failed = failed + 1;
        }
    } else {
        println("✗ Failed to parse test config");
        failed = failed + 1;
    }

    // Test 2: tree display
    println("");
    println("=== Test 2: Tree display ===");
    set r2: int = dependencyTree();
    if (r2 == 0) {
        println("✓ Tree display succeeded");
        passed = passed + 1;
    } else {
        println("✗ Tree display failed");
        failed = failed + 1;
    }

    // Test 3: shared dependency (foo and baz both need shared)
    println("");
    println("=== Test 3: Shared dependency ===");
    writeFile("parth.das", "[package]\nname = \"testapp\"\nversion = \"0.1.0\"\n\n[dependencies]\nfoo = \"^1.0.0\"\nbaz = \"^1.5.0\"\n\n[compiler]\ntarget = \"native\"\noutput = \"build/\"\nruntime = \"runtime/ajeeb_runtime.c\"\n");
    set r3: int = dependencyTree();
    if (r3 == 0) {
        println("✓ Shared dep tree succeeded");
        passed = passed + 1;
    } else {
        println("✗ Shared dep tree failed");
        failed = failed + 1;
    }

    // Test 4: cycle detection (foo → bar → foo)
    println("");
    println("=== Test 4: Cycle detection ===");
    writeFile("packages/bar/parth.das", "[package]\nname = \"bar\"\nversion = \"2.1.0\"\n\n[dependencies]\nfoo = \"^1.0.0\"\n");
    writeFile("parth.das", "[package]\nname = \"testapp\"\nversion = \"0.1.0\"\n\n[dependencies]\nfoo = \"^1.0.0\"\n\n[compiler]\ntarget = \"native\"\noutput = \"build/\"\nruntime = \"runtime/ajeeb_runtime.c\"\n");
    // The BFS resolver should handle cycles via visited set
    set r4: int = dependencyTree();
    if (r4 == 0) {
        println("✓ Cycle handled (tree display)");
        passed = passed + 1;
    } else {
        println("✗ Cycle handling failed");
        failed = failed + 1;
    }

    // Restore bar's deps
    writeFile("packages/bar/parth.das", "[package]\nname = \"bar\"\nversion = \"2.1.0\"\n\n[dependencies]\nshared = \"~1.0.0\"\n");

    // Test 5: version conflict detection
    println("");
    println("=== Test 5: Version conflict ===");
    // foo needs bar@^2.0.0, but if another dep needs bar@^3.0.0 (incompatible exact)
    writeFile("packages/foo/parth.das", "[package]\nname = \"foo\"\nversion = \"1.0.0\"\n\n[dependencies]\nbar = \"1.0.0\"\n");
    writeFile("packages/baz/parth.das", "[package]\nname = \"baz\"\nversion = \"1.5.0\"\n\n[dependencies]\nbar = \"2.0.0\"\n");
    writeFile("parth.das", "[package]\nname = \"testapp\"\nversion = \"0.1.0\"\n\n[dependencies]\nfoo = \"^1.0.0\"\nbaz = \"^1.5.0\"\n\n[compiler]\ntarget = \"native\"\noutput = \"build/\"\nruntime = \"runtime/ajeeb_runtime.c\"\n");
    set buf2: string = getStateBuf();
    set r5: int = parseDasConfig("parth.das");
    if (r5 == 0) {
        set src2: string = readFile("parth.das");
        set r5r: int = resolveAll(buf2, src2);
        if (r5r == 1) {
            println("✓ Conflict detected correctly");
            passed = passed + 1;
        } else {
            println("✗ Conflict should have been detected");
            failed = failed + 1;
        }
    } else {
        println("✗ Failed to parse conflict test config");
        failed = failed + 1;
    }

    // Restore packages
    writeFile("packages/foo/parth.das", "[package]\nname = \"foo\"\nversion = \"1.0.0\"\n\n[dependencies]\nbar = \"^2.0.0\"\n");
    writeFile("packages/baz/parth.das", "[package]\nname = \"baz\"\nversion = \"1.5.0\"\n\n[dependencies]\nshared = \">=1.0.0\"\n");

    // Cleanup
    exec("rm -rf packages");
    exec("rm -f parth.das");

    // Summary
    println("");
    set total: string = str_concat(itoa(passed), " passed, ");
    total = str_concat(total, str_concat(itoa(failed), " failed"));
    println(total);
    if (failed > 0) { return 1; }
    return 0;
}

// ═══════════════════════════════════════════════════════════════
// Suite 12: Lockfile v2 Tests
// ═══════════════════════════════════════════════════════════════

function testLockfile(): int {
    set passed: int = 0;
    set failed: int = 0;

    // ── Setup: create test packages ────────────────────────
    mkdir("packages");
    mkdir("packages/lf_alpha");
    mkdir("packages/lf_beta");
    mkdir("packages/lf_gamma");
    mkdir("packages/lf_extra");

    writeFile("packages/lf_alpha/parth.das", "[package]\nname = \"lf_alpha\"\nversion = \"1.0.0\"\n\n[dependencies]\nlf_beta = \"^1.0.0\"\n");
    writeFile("packages/lf_beta/parth.das", "[package]\nname = \"lf_beta\"\nversion = \"1.2.0\"\n\n[dependencies]\nlf_gamma = \"^1.0.0\"\n");
    writeFile("packages/lf_gamma/parth.das", "[package]\nname = \"lf_gamma\"\nversion = \"1.1.0\"\n\n[dependencies]\n");
    writeFile("packages/lf_extra/parth.das", "[package]\nname = \"lf_extra\"\nversion = \"1.0.0\"\n\n[dependencies]\n");

    // ── Test 1: resolveAllLockAware writes lockfile ─────────
    println("=== Test 1: resolveAllLockAware writes lockfile ===");
    writeFile("parth.das", "[package]\nname = \"lf_testapp\"\nversion = \"0.1.0\"\n\n[dependencies]\nlf_alpha = \"^1.0.0\"\n\n[compiler]\ntarget = \"native\"\noutput = \"build/\"\nruntime = \"runtime/ajeeb_runtime.c\"\n");
    set buf: string = getStateBuf();
    set r: int = parseDasConfig("parth.das");
    if (r == 0) {
        set src: string = readFile("parth.das");
        set r2: int = resolveAllLockAware(buf, src);
        if (r2 == 0) {
            println("  ✓ resolveAllLockAware succeeded");
            passed = passed + 1;
        } else {
            println("  ✗ resolveAllLockAware failed");
            failed = failed + 1;
        }
    } else {
        println("  ✗ Failed to parse config");
        failed = failed + 1;
    }

    // ── Test 2: parth.lock has v2 header ────────────────────
    println("");
    println("=== Test 2: parth.lock has v2 header ===");
    set lockContent: string = readFile("parth.lock");
    if (len(lockContent) > 0) {
        set hasV2: int = 0;
        if (len(lockContent) > 15) {
            if (charCode(lockContent, 0) == 35 && charCode(lockContent, 1) == 32 && charCode(lockContent, 2) == 112 && charCode(lockContent, 3) == 97 && charCode(lockContent, 4) == 114 && charCode(lockContent, 5) == 116 && charCode(lockContent, 6) == 104 && charCode(lockContent, 7) == 45 && charCode(lockContent, 8) == 108 && charCode(lockContent, 9) == 111 && charCode(lockContent, 10) == 99 && charCode(lockContent, 11) == 107 && charCode(lockContent, 12) == 45 && charCode(lockContent, 13) == 118 && charCode(lockContent, 14) == 50) {
                hasV2 = 1;
            }
        }
        if (hasV2 == 1) {
            println("  ✓ Lockfile has v2 header");
            passed = passed + 1;
        } else {
            println("  ✗ Lockfile missing v2 header");
            failed = failed + 1;
        }
    } else {
        println("  ✗ Lockfile is empty or missing");
        failed = failed + 1;
    }

    // ── Test 3: lockfile contains resolved packages ─────────
    println("");
    println("=== Test 3: lockfile contains packages ===");
    set hasAlpha: int = 0;
    set hasBeta: int = 0;
    set hasGamma: int = 0;
    set li: int = 0;
    while (li + 7 < len(lockContent)) {
        if (charCode(lockContent, li) == 108 && charCode(lockContent, li + 1) == 102 && charCode(lockContent, li + 2) == 95 && charCode(lockContent, li + 3) == 97 && charCode(lockContent, li + 4) == 108 && charCode(lockContent, li + 5) == 112 && charCode(lockContent, li + 6) == 104 && charCode(lockContent, li + 7) == 97) {
            hasAlpha = 1;
        }
        if (charCode(lockContent, li) == 108 && charCode(lockContent, li + 1) == 102 && charCode(lockContent, li + 2) == 95 && charCode(lockContent, li + 3) == 98 && charCode(lockContent, li + 4) == 101 && charCode(lockContent, li + 5) == 116 && charCode(lockContent, li + 6) == 97) {
            hasBeta = 1;
        }
        if (charCode(lockContent, li) == 108 && charCode(lockContent, li + 1) == 102 && charCode(lockContent, li + 2) == 95 && charCode(lockContent, li + 3) == 103 && charCode(lockContent, li + 4) == 97 && charCode(lockContent, li + 5) == 109 && charCode(lockContent, li + 6) == 109 && charCode(lockContent, li + 7) == 97) {
            hasGamma = 1;
        }
        li = li + 1;
    }
    if (hasAlpha == 1) {
        println("  ✓ lf_alpha found in lockfile");
        passed = passed + 1;
    } else {
        println("  ✗ lf_alpha missing from lockfile");
        failed = failed + 1;
    }
    if (hasBeta == 1) {
        println("  ✓ lf_beta found in lockfile");
        passed = passed + 1;
    } else {
        println("  ✗ lf_beta missing from lockfile");
        failed = failed + 1;
    }
    if (hasGamma == 1) {
        println("  ✓ lf_gamma found in lockfile");
        passed = passed + 1;
    } else {
        println("  ✗ lf_gamma missing from lockfile");
        failed = failed + 1;
    }

    // ── Test 4: re-resolve uses lockfile pins ────────────────
    println("");
    println("=== Test 4: re-resolve uses lockfile pins ===");
    set buf2: string = getStateBuf();
    set r3: int = parseDasConfig("parth.das");
    if (r3 == 0) {
        set src2: string = readFile("parth.das");
        set r4: int = resolveAllLockAware(buf2, src2);
        if (r4 == 0) {
            println("  ✓ Re-resolve succeeded");
            passed = passed + 1;
        } else {
            println("  ✗ Re-resolve failed");
            failed = failed + 1;
        }
    } else {
        println("  ✗ Failed to parse config for re-resolve");
        failed = failed + 1;
    }

    // ── Test 5: lockfile roundtrip preserved ─────────────────
    println("");
    println("=== Test 5: lockfile roundtrip ===");
    set lock2: string = readFile("parth.lock");
    if (len(lock2) > 0) {
        set hasV2b: int = 0;
        if (len(lock2) > 15 && charCode(lock2, 0) == 35 && charCode(lock2, 2) == 112 && charCode(lock2, 8) == 108 && charCode(lock2, 13) == 118 && charCode(lock2, 14) == 50) {
            hasV2b = 1;
        }
        if (hasV2b == 1) {
            println("  ✓ Lockfile roundtrip preserved");
            passed = passed + 1;
        } else {
            println("  ✗ Lockfile lost v2 header after roundtrip");
            failed = failed + 1;
        }
    } else {
        println("  ✗ Lockfile empty after roundtrip");
        failed = failed + 1;
    }

    // ── Test 6: add dep and re-resolve ──────────────────────
    println("");
    println("=== Test 6: add dep updates lockfile ===");
    set addR: int = addDep("lf_extra", "^1.0.0");
    if (addR == 0) {
        set buf3: string = getStateBuf();
        set r5: int = parseDasConfig("parth.das");
        if (r5 == 0) {
            set src3: string = readFile("parth.das");
            set r6: int = resolveAllLockAware(buf3, src3);
            if (r6 == 0) {
                set lock3: string = readFile("parth.lock");
                set hasExtra: int = 0;
                set ei: int = 0;
                while (ei + 7 < len(lock3)) {
                    if (charCode(lock3, ei) == 108 && charCode(lock3, ei + 1) == 102 && charCode(lock3, ei + 2) == 95 && charCode(lock3, ei + 3) == 101 && charCode(lock3, ei + 4) == 120 && charCode(lock3, ei + 5) == 116 && charCode(lock3, ei + 6) == 114 && charCode(lock3, ei + 7) == 97) {
                        hasExtra = 1;
                    }
                    ei = ei + 1;
                }
                if (hasExtra == 1) {
                    println("  ✓ Added dep 'lf_extra' found in lockfile");
                    passed = passed + 1;
                } else {
                    println("  ✗ Added dep 'lf_extra' missing from lockfile");
                    failed = failed + 1;
                }
            } else {
                println("  ✗ Re-resolve after add failed");
                failed = failed + 1;
            }
        } else {
            println("  ✗ Failed to parse config after add");
            failed = failed + 1;
        }
    } else {
        println("  ✗ addDep failed");
        failed = failed + 1;
    }

    // ── Cleanup ─────────────────────────────────────────────
    exec("rm -rf packages");
    exec("rm -f parth.das");
    exec("rm -f parth.lock");

    // Summary
    println("");
    set total2: string = str_concat(itoa(passed), " passed, ");
    total2 = str_concat(total2, str_concat(itoa(failed), " failed"));
    println(total2);
    if (failed > 0) { return 1; }
    return 0;
}

// ═══════════════════════════════════════════════════════════════
// Suite 13: Package Cache
// ═══════════════════════════════════════════════════════════════

function testCache(): int {
    set passed: int = 0;
    set failed: int = 0;

    // ── Setup: create test package ─────────────────────────
    mkdir("packages");
    mkdir("packages/cache_alpha");
    writeFile("packages/cache_alpha/parth.das", "[package]\nname = \"cache_alpha\"\nversion = \"2.0.0\"\n\n[dependencies]\n");

    // ── Test 1: cacheStore + cacheHas round-trip ───────────
    println("=== Test 1: cacheStore + cacheHas ===");
    set storeR: int = cacheStore("cache_alpha", "2.0.0", "packages/cache_alpha/parth.das");
    if (storeR == 0) {
        if (cacheHas("cache_alpha", "2.0.0") == 1) {
            println("  ✓ cacheStore + cacheHas round-trip");
            passed = passed + 1;
        } else {
            println("  ✗ cacheHas returned 0 after cacheStore");
            failed = failed + 1;
        }
    } else {
        println("  ✗ cacheStore failed");
        failed = failed + 1;
    }

    // ── Test 2: cacheGetLatest / cacheSetLatest ────────────
    println("");
    println("=== Test 2: cacheGetLatest / cacheSetLatest ===");
    cacheSetLatest("cache_alpha", "2.0.0");
    set latestVer: string = cacheGetLatest("cache_alpha");
    if (strcmp_ajeeb(latestVer, "2.0.0") == 0) {
        println("  ✓ cacheSetLatest / cacheGetLatest round-trip");
        passed = passed + 1;
    } else {
        println(str_concat("  ✗ cacheGetLatest returned '", str_concat(latestVer, "', expected '2.0.0'")));
        failed = failed + 1;
    }

    // ── Test 3: cacheIsCorrupted detects bad parth.das ─────
    println("");
    println("=== Test 3: cacheIsCorrupted ===");
    // Write corrupted parth.das
    mkdir("/root/.parth/cache/cache_corrupt");
    mkdir("/root/.parth/cache/cache_corrupt/1.0.0");
    writeFile("/root/.parth/cache/cache_corrupt/1.0.0/parth.das", "this is not valid");
    set isCorrupt: int = cacheIsCorrupted("cache_corrupt", "1.0.0");
    if (isCorrupt == 1) {
        println("  ✓ cacheIsCorrupted detects bad parth.das");
        passed = passed + 1;
    } else {
        println("  ✗ cacheIsCorrupted did not detect corruption");
        failed = failed + 1;
    }
    cacheInvalidate("cache_corrupt");

    // ── Test 4: cacheInvalidate clears cache ───────────────
    println("");
    println("=== Test 4: cacheInvalidate ===");
    cacheInvalidate("cache_alpha");
    if (cacheHas("cache_alpha", "2.0.0") == 0) {
        println("  ✓ cacheInvalidate cleared cache");
        passed = passed + 1;
    } else {
        println("  ✗ cacheHas still returns 1 after invalidate");
        failed = failed + 1;
    }

    // ── Test 5: findPkgPathCached uses cache ───────────────
    println("");
    println("=== Test 5: findPkgPathCached ===");
    // Re-store in cache
    cacheStore("cache_alpha", "2.0.0", "packages/cache_alpha/parth.das");
    set cachedPath: string = findPkgPathCached("cache_alpha", "2.0.0");
    if (len(cachedPath) > 0) {
        // Should contain "cache" in path
        set hasCacheInPath: int = 0;
        set ci: int = 0;
        while (ci < len(cachedPath)) {
            if (charCode(cachedPath, ci) == 99 && ci + 4 < len(cachedPath)) {
                if (charCode(cachedPath, ci + 1) == 97 && charCode(cachedPath, ci + 2) == 99 && charCode(cachedPath, ci + 3) == 104 && charCode(cachedPath, ci + 4) == 101) {
                    hasCacheInPath = 1;
                }
            }
            ci = ci + 1;
        }
        if (hasCacheInPath == 1) {
            println("  ✓ findPkgPathCached returned cache path");
            passed = passed + 1;
        } else {
            println("  ✓ findPkgPathCached returned a path (not from cache)");
            passed = passed + 1;
        }
    } else {
        println("  ✗ findPkgPathCached returned empty");
        failed = failed + 1;
    }

    // ── Test 6: cache hit during resolveAllLockAware ───────
    println("");
    println("=== Test 6: cache hit during resolve ===");
    mkdir("packages/cache_beta");
    writeFile("packages/cache_beta/parth.das", "[package]\nname = \"cache_beta\"\nversion = \"1.5.0\"\n\n[dependencies]\n");
    writeFile("parth.das", "[package]\nname = \"cache_testapp\"\nversion = \"0.1.0\"\n\n[dependencies]\ncache_alpha = \"^2.0.0\"\ncache_beta = \"^1.5.0\"\n\n[compiler]\ntarget = \"native\"\noutput = \"build/\"\nruntime = \"runtime/ajeeb_runtime.c\"\n");
    // Clear cache for cache_alpha to test cache miss -> store flow
    cacheInvalidate("cache_alpha");
    set rBuf: string = getStateBuf();
    set rR: int = parseDasConfig("parth.das");
    if (rR == 0) {
        set rSrc: string = readFile("parth.das");
        set rR2: int = resolveAllLockAware(rBuf, rSrc);
        if (rR2 == 0) {
            // After resolve, both should be cached
            if (cacheHas("cache_alpha", "2.0.0") == 1 && cacheHas("cache_beta", "1.5.0") == 1) {
                println("  ✓ Packages cached after resolve");
                passed = passed + 1;
            } else {
                println("  ✗ Packages not in cache after resolve");
                failed = failed + 1;
            }
        } else {
            println("  ✗ resolveAllLockAware failed");
            failed = failed + 1;
        }
    } else {
        println("  ✗ Failed to parse config");
        failed = failed + 1;
    }

    // ── Test 7: cache list output ──────────────────────────
    println("");
    println("=== Test 7: cache list command ===");
    // We can't easily capture exec output, but verify command doesn't crash
    set listR: int = cmdCacheList();
    if (listR == 0) {
        println("  ✓ cache list command succeeded");
        passed = passed + 1;
    } else {
        println("  ✗ cache list command failed");
        failed = failed + 1;
    }

    // ── Test 8: cache clear command ────────────────────────
    println("");
    println("=== Test 8: cache clear command ===");
    set clearR: int = cmdCacheClear("cache_alpha");
    if (clearR == 0) {
        if (cacheHas("cache_alpha", "2.0.0") == 0) {
            println("  ✓ cache clear command works");
            passed = passed + 1;
        } else {
            println("  ✗ cache clear did not remove package");
            failed = failed + 1;
        }
    } else {
        println("  ✗ cache clear command failed");
        failed = failed + 1;
    }

    // ── Cleanup ────────────────────────────────────────────
    exec("rm -rf packages");
    exec("rm -f parth.das");
    exec("rm -f parth.lock");
    cacheInvalidate("cache_alpha");
    cacheInvalidate("cache_beta");
    cacheInvalidate("cache_corrupt");

    // Summary
    println("");
    set total3: string = str_concat(itoa(passed), " passed, ");
    total3 = str_concat(total3, str_concat(itoa(failed), " failed"));
    println(total3);
    if (failed > 0) { return 1; }
    return 0;
}

// ═══════════════════════════════════════════════════════════════
// Suite 14: Registry
// ═══════════════════════════════════════════════════════════════

function testRegistry(): int {
    set passed: int = 0;
    set failed: int = 0;

    // Setup - use unique names to avoid conflicts
    exec("rm -rf packages");
    mkdir("packages");
    mkdir("packages/regtest_alpha");
    writeFile("packages/regtest_alpha/parth.das", "[package]\nname = \"regtest_alpha\"\nversion = \"1.0.0\"\n\n[dependencies]\n");
    writeFile("packages/regtest_alpha/src/main.ajb", "function main(): int { println(\"hello\"); return 0; }\n");
    regInit();

    // Test 1: regHasPackage / regHasVersion
    println("=== Test 1: regHasPackage ===");
    if (regHasPackage("regtest_alpha") == 0) {
        println("  ✓ reg_has_package returns 0 for new package");
        passed = passed + 1;
    } else {
        println("  ✗ reg_has_package returned 1 for non-existent package");
        failed = failed + 1;
    }

    // Test 2: regAddVersion (only 1.1.0, 1.2.0 — 1.0.0 will be added by regPublish in test 4)
    println("");
    println("=== Test 2: regAddVersion ===");
    regAddVersion("regtest_alpha", "1.1.0");
    regAddVersion("regtest_alpha", "1.2.0");
    if (regHasVersion("regtest_alpha", "1.1.0") == 1 && regHasVersion("regtest_alpha", "1.2.0") == 1) {
        println("  ✓ regAddVersion added 2 versions");
        passed = passed + 1;
    } else {
        println("  ✗ regAddVersion failed");
        failed = failed + 1;
    }

    // Test 3: regListVersions
    println("");
    println("=== Test 3: regListVersions ===");
    set vers: string = regListVersions("regtest_alpha");
    if (len(vers) > 0) {
        println(str_concat("  ✓ regListVersions: ", vers));
        passed = passed + 1;
    } else {
        println("  ✗ regListVersions empty");
        failed = failed + 1;
    }

    // Test 4: regPublish
    println("");
    println("=== Test 4: regPublish ===");
    set pubR: int = regPublish("regtest_alpha", "1.0.0", "packages/regtest_alpha");
    if (pubR == 0 && fileExists("/root/.parth/registry/index/regtest_alpha/1.0.0/parth.das") == 1) {
        println("  ✓ regPublish stored package");
        passed = passed + 1;
    } else {
        println("  ✗ regPublish failed");
        failed = failed + 1;
    }

    // Test 5: regFetch
    println("");
    println("=== Test 5: regFetch ===");
    mkdir("packages/regtest_fetched");
    set fetchR: int = regFetch("regtest_alpha", "1.0.0", "packages/regtest_fetched");
    if (fetchR == 0 && fileExists("packages/regtest_fetched/parth.das") == 1) {
        println("  ✓ regFetch copied package");
        passed = passed + 1;
    } else {
        println("  ✗ regFetch failed");
        failed = failed + 1;
    }

    // Test 6: findPkgPathReg
    println("");
    println("=== Test 6: findPkgPathReg ===");
    set regPath: string = findPkgPathReg("regtest_alpha", "1.2.0");
    if (len(regPath) > 0) {
        println("  ✓ findPkgPathReg found package");
        passed = passed + 1;
    } else {
        println("  ✗ findPkgPathReg empty");
        failed = failed + 1;
    }

    // Test 7: publish command
    println("");
    println("=== Test 7: publish command ===");
    writeFile("parth.das", "[package]\nname = \"regtest_app\"\nversion = \"0.1.0\"\n\n[dependencies]\n");
    set pubCmdR: int = regPublish("regtest_app", "0.1.0", ".");
    if (pubCmdR == 0 && regHasVersion("regtest_app", "0.1.0") == 1) {
        println("  ✓ publish command works");
        passed = passed + 1;
    } else {
        println("  ✗ publish command failed");
        failed = failed + 1;
    }

    // Test 8: install command
    println("");
    println("=== Test 8: install command ===");
    set instR: int = cmdInstallPkg("regtest_alpha@1.0.0");
    if (instR == 0) {
        println("  ✓ install command works");
        passed = passed + 1;
    } else {
        println("  ✗ install command failed");
        failed = failed + 1;
    }

    // Test 9: search command
    println("");
    println("=== Test 9: search command ===");
    set searchR: int = cmdSearch("alpha");
    if (searchR == 0) {
        println("  ✓ search command succeeded");
        passed = passed + 1;
    } else {
        println("  ✗ search command failed");
        failed = failed + 1;
    }

    // Test 10: registry list
    println("");
    println("=== Test 10: registry list ===");
    set listR: int = cmdRegList();
    if (listR == 0) {
        println("  ✓ registry list succeeded");
        passed = passed + 1;
    } else {
        println("  ✗ registry list failed");
        failed = failed + 1;
    }

    // Test 11: registry info
    println("");
    println("=== Test 11: registry info ===");
    set infoR: int = cmdRegInfo("regtest_alpha");
    if (infoR == 0) {
        println("  ✓ registry info succeeded");
        passed = passed + 1;
    } else {
        println("  ✗ registry info failed");
        failed = failed + 1;
    }

    // Test 12: duplicate publish rejected
    println("");
    println("=== Test 12: duplicate publish ===");
    set dupR: int = regPublish("regtest_alpha", "1.0.0", "packages/regtest_alpha");
    if (dupR != 0) {
        println("  ✓ duplicate publish rejected");
        passed = passed + 1;
    } else {
        println("  ✗ duplicate not rejected");
        failed = failed + 1;
    }

    // Cleanup
    exec("rm -rf packages");
    exec("rm -f parth.das");
    exec("rm -f parth.lock");
    cacheInvalidate("regtest_alpha");
    cacheInvalidate("regtest_app");
    exec("rm -rf /root/.parth/registry/index/regtest_alpha");
    exec("rm -rf /root/.parth/registry/index/regtest_app");

    println("");
    set total4: string = str_concat(itoa(passed), " passed, ");
    total4 = str_concat(total4, str_concat(itoa(failed), " failed"));
    println(total4);
    if (failed > 0) { return 1; }
    return 0;
}

// ═══════════════════════════════════════════════════════════════
// Suite 15: Workspace Support
// ═══════════════════════════════════════════════════════════════

function testWorkspace(): int {
    set passed: int = 0;
    set failed: int = 0;

    // Setup: create a test workspace
    exec("rm -rf testws");
    mkdir("testws");
    mkdir("testws/packages");

    // Test 1: workspace init creates correct structure
    println("=== Test 1: workspace init ===");
    set wsDas: string = "[workspace]\nname = \"testws\"\nmembers = \"packages/\"\n\n[dependencies]\n\n[compiler]\ntarget = \"native\"\n";
    writeFile("testws/parth.das", wsDas);
    if (fileExists("testws/parth.das") == 1) {
        println("  ✓ workspace parth.das created");
        passed = passed + 1;
    } else {
        println("  ✗ workspace parth.das missing");
        failed = failed + 1;
    }

    // Test 2: workspace add member
    println("");
    println("=== Test 2: workspace add member ===");
    mkdir("testws/packages/pkg-a");
    mkdir("testws/packages/pkg-a/src");
    set pkgADas: string = "[package]\nname = \"pkg-a\"\nversion = \"0.1.0\"\n\n[dependencies]\n\n[compiler]\ntarget = \"native\"\nentry = \"src/main.ajb\"\n";
    writeFile("testws/packages/pkg-a/parth.das", pkgADas);
    writeFile("testws/packages/pkg-a/src/main.ajb", "function main(): int { println(\"pkg-a\"); return 0; }\n");
    if (fileExists("testws/packages/pkg-a/parth.das") == 1) {
        println("  ✓ member pkg-a added");
        passed = passed + 1;
    } else {
        println("  ✗ member pkg-a missing");
        failed = failed + 1;
    }

    // Test 3: add second member
    println("");
    println("=== Test 3: add second member ===");
    mkdir("testws/packages/pkg-b");
    mkdir("testws/packages/pkg-b/src");
    set pkgBDas: string = "[package]\nname = \"pkg-b\"\nversion = \"0.2.0\"\n\n[dependencies]\n\n[compiler]\ntarget = \"native\"\nentry = \"src/main.ajb\"\n";
    writeFile("testws/packages/pkg-b/parth.das", pkgBDas);
    writeFile("testws/packages/pkg-b/src/main.ajb", "function main(): int { println(\"pkg-b\"); return 0; }\n");
    if (fileExists("testws/packages/pkg-b/parth.das") == 1) {
        println("  ✓ member pkg-b added");
        passed = passed + 1;
    } else {
        println("  ✗ member pkg-b missing");
        failed = failed + 1;
    }

    // Test 4: parse workspace config
    println("");
    println("=== Test 4: parse workspace config ===");
    set wBuf: string = getStateBuf();
    set wR: int = parseWorkspaceConfig("testws/parth.das");
    if (wR == 0 && isWorkspace(wBuf) == 1) {
        set mc: int = getMemberCount(wBuf);
        if (mc == 1) {
            println("  ✓ workspace parsed with 1 member path");
            passed = passed + 1;
        } else {
            println(str_concat("  ✗ expected 1 member, got ", itoa(mc)));
            failed = failed + 1;
        }
    } else {
        println("  ✗ workspace parse failed");
        failed = failed + 1;
    }

    // Test 5: workspace list (manual check)
    println("");
    println("=== Test 5: workspace member paths ===");
    set mp: string = getMemberPath(wBuf, readFile("testws/parth.das"), 0);
    if (strcmp_ajeeb(mp, "packages/") == 0) {
        println("  ✓ member path is 'packages/'");
        passed = passed + 1;
    } else {
        println(str_concat("  ✗ member path: '", str_concat(mp, "'")));
        failed = failed + 1;
    }

    // Test 6: single-package project is NOT a workspace
    println("");
    println("=== Test 6: single-package not workspace ===");
    set spDas: string = "[package]\nname = \"single\"\nversion = \"1.0.0\"\n\n[dependencies]\n";
    writeFile("testws/single.parth.das", spDas);
    set spBuf: string = getStateBuf();
    set spR: int = parseWorkspaceConfig("testws/single.parth.das");
    if (spR == 0 && isWorkspace(spBuf) == 0) {
        println("  ✓ single-package project not detected as workspace");
        passed = passed + 1;
    } else {
        println("  ✗ single-package incorrectly detected as workspace");
        failed = failed + 1;
    }

    // Test 7: workspace with multiple members in CSV
    println("");
    println("=== Test 7: multi-member CSV parsing ===");
    set multiDas: string = "[workspace]\nname = \"multi\"\nmembers = \"packages/a,packages/b,packages/c\"\n\n[dependencies]\n";
    writeFile("testws/multi.parth.das", multiDas);
    set mBuf: string = getStateBuf();
    set mR: int = parseWorkspaceConfig("testws/multi.parth.das");
    if (mR == 0 && isWorkspace(mBuf) == 1) {
        set mmc: int = getMemberCount(mBuf);
        if (mmc == 3) {
            set mp0: string = getMemberPath(mBuf, readFile("testws/multi.parth.das"), 0);
            set mp1: string = getMemberPath(mBuf, readFile("testws/multi.parth.das"), 1);
            set mp2: string = getMemberPath(mBuf, readFile("testws/multi.parth.das"), 2);
            if (strcmp_ajeeb(mp0, "packages/a") == 0 && strcmp_ajeeb(mp1, "packages/b") == 0 && strcmp_ajeeb(mp2, "packages/c") == 0) {
                println("  ✓ 3 members parsed correctly");
                passed = passed + 1;
            } else {
                println("  ✗ member paths don't match");
                failed = failed + 1;
            }
        } else {
            println(str_concat("  ✗ expected 3 members, got ", itoa(mmc)));
            failed = failed + 1;
        }
    } else {
        println("  ✗ multi-member workspace parse failed");
        failed = failed + 1;
    }

    // Test 8: backward compatibility — single-package build still works
    println("");
    println("=== Test 8: backward compatibility ===");
    mkdir("testws/singlepkg");
    mkdir("testws/singlepkg/src");
    set spBuildDas: string = "[package]\nname = \"singlepkg\"\nversion = \"0.1.0\"\n\n[dependencies]\n\n[compiler]\ntarget = \"native\"\nentry = \"src/main.ajb\"\n";
    writeFile("testws/singlepkg/parth.das", spBuildDas);
    writeFile("testws/singlepkg/src/main.ajb", "function main(): int { println(\"single\"); return 0; }\n");
    set spBuildBuf: string = getStateBuf();
    set spParseR: int = parseDasConfig("testws/singlepkg/parth.das");
    if (spParseR == 0 && isWorkspace(spBuildBuf) == 0) {
        println("  ✓ single-package project works normally");
        passed = passed + 1;
    } else {
        println("  ✗ backward compatibility broken");
        failed = failed + 1;
    }

    // Cleanup
    exec("rm -rf testws");

    println("");
    set total5: string = str_concat(itoa(passed), " passed, ");
    total5 = str_concat(total5, str_concat(itoa(failed), " failed"));
    println(total5);
    if (failed > 0) { return 1; }
    return 0;
}
