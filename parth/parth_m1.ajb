    if (r10 == 0) { totalPassed = totalPassed + 1; } else { totalFailed = totalFailed + 1; }
    println("");

    // ── Suite 11: E2E — tree with transitive deps ──────────
    suiteNum = suiteNum + 1;
    println(str_concat(itoa(suiteNum), ". E2E: dependency tree display"));
    println("────────────────────────────────────────");
    set r11: int = testE2ETree();
    if (r11 == 0) { totalPassed = totalPassed + 1; } else { totalFailed = totalFailed + 1; }
    println("");

    // ── Suite 12: Lockfile v2 ─────────────────────────────
    suiteNum = suiteNum + 1;
    println(str_concat(itoa(suiteNum), ". Lockfile v2"));
