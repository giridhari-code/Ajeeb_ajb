    if (r9 == 0) { totalPassed = totalPassed + 1; } else { totalFailed = totalFailed + 1; }
    println("");

    // ── Suite 10: E2E — run command ─────────────────────────
    suiteNum = suiteNum + 1;
    println(str_concat(itoa(suiteNum), ". E2E: run command"));
    println("────────────────────────────────────────");
    set r10: int = testE2ERun();
    if (r10 == 0) { totalPassed = totalPassed + 1; } else { totalFailed = totalFailed + 1; }
    println("");

    // ── Suite 11: E2E — tree with transitive deps ──────────
    suiteNum = suiteNum + 1;
    println(str_concat(itoa(suiteNum), ". E2E: dependency tree display"));
    println("────────────────────────────────────────");
    set r11: int = testE2ETree();
    if (r11 == 0) { totalPassed = totalPassed + 1; } else { totalFailed = totalFailed + 1; }
    println("");

    // ── Suite 12: Lockfile v2 ─────────────────────────────
    suiteNum = suiteNum + 1;
    println(str_concat(itoa(suiteNum), ". Lockfile v2"));
    println("────────────────────────────────────────");
    set r12: int = testLockfile();
    if (r12 == 0) { totalPassed = totalPassed + 1; } else { totalFailed = totalFailed + 1; }
    println("");

    // ── Suite 13: Package Cache ───────────────────────────
    suiteNum = suiteNum + 1;
    println(str_concat(itoa(suiteNum), ". Package Cache"));
    println("────────────────────────────────────────");
    set r13: int = testCache();
    if (r13 == 0) { totalPassed = totalPassed + 1; } else { totalFailed = totalFailed + 1; }
    println("");

    // ── Suite 14: Registry ───────────────────────────────
    suiteNum = suiteNum + 1;
    println(str_concat(itoa(suiteNum), ". Registry"));
    println("────────────────────────────────────────");
    set r14: int = testRegistry();
    if (r14 == 0) { totalPassed = totalPassed + 1; } else { totalFailed = totalFailed + 1; }
    println("");

    // ── Suite 15: Workspace ──────────────────────────────
    suiteNum = suiteNum + 1;
    println(str_concat(itoa(suiteNum), ". Workspace Support"));
    println("────────────────────────────────────────");
    set r15: int = testWorkspace();
    if (r15 == 0) { totalPassed = totalPassed + 1; } else { totalFailed = totalFailed + 1; }
    println("");

    // ── Final Summary ────────────────────────────────────────
    println("══════════════════════════════════════════════════");
    set summary: string = str_concat("Suites: ", itoa(totalPassed));
    summary = str_concat(summary, " passed, ");
    summary = str_concat(summary, itoa(totalFailed));
    summary = str_concat(summary, " failed out of ");
    summary = str_concat(summary, itoa(suiteNum));
    println(summary);
    if (totalFailed > 0) {
        println("RESULT: FAIL");
        return 1;
    }
    println("RESULT: ALL PASS");
    return 0;
}

// ═══════════════════════════════════════════════════════════════
// Suite 1: Regression Tests
// ═══════════════════════════════════════════════════════════════

function testRegression(): int {
    set passed: int = 0;
    set failed: int = 0;

    // ── R1: strcmp_ajeeb equality semantics ─────────────────
    // strcmp_ajeeb returns 0 for equal, non-zero for not equal
    if (strcmp_ajeeb("hello", "hello") == 0) {
        println("  ✓ R1a: strcmp_ajeeb(\"hello\",\"hello\") == 0");
        passed = passed + 1;
    } else {
        println("  ✗ R1a: strcmp_ajeeb equality broken");
        failed = failed + 1;
    }
    if (strcmp_ajeeb("hello", "world") != 0) {
        println("  ✓ R1b: strcmp_ajeeb(\"hello\",\"world\") != 0");
        passed = passed + 1;
    } else {
        println("  ✗ R1b: strcmp_ajeeb inequality broken");
        failed = failed + 1;
    }
    if (strcmp_ajeeb("", "") == 0) {
        println("  ✓ R1c: strcmp_ajeeb(\"\",\"\") == 0");
        passed = passed + 1;
    } else {
        println("  ✗ R1c: empty string equality broken");
        failed = failed + 1;
    }

    // ── R2: csvContains uses strcmp correctly ────────────────
    if (csvContains("foo,bar,baz", "bar") == 1) {
        println("  ✓ R2a: csvContains finds 'bar' in list");
        passed = passed + 1;
    } else {
        println("  ✗ R2a: csvContains missed 'bar'");
        failed = failed + 1;
    }
    if (csvContains("foo,bar,baz", "qux") == 0) {
        println("  ✓ R2b: csvContains rejects 'qux'");
        passed = passed + 1;
    } else {
        println("  ✗ R2b: false positive in csvContains");
        failed = failed + 1;
    }
    if (csvContains("foo", "foo") == 1) {
        println("  ✓ R2c: csvContains single item match");
        passed = passed + 1;
    } else {
        println("  ✗ R2c: single item csvContains broken");
        failed = failed + 1;
    }
    if (csvContains("", "foo") == 0) {
        println("  ✓ R2d: csvContains empty string");
        passed = passed + 1;
    } else {
        println("  ✗ R2d: empty csvContains broken");
        failed = failed + 1;
    }

    // ── R3: Buffer aliasing — string vars survive parseDasConfig ──
    mkdir("packages");
    mkdir("packages/regtest");
    writeFile("packages/regtest/parth.das", "[package]\nname = \"regtest\"\nversion = \"1.0.0\"\n\n[dependencies]\nfoo = \"^1.0.0\"\n");
    writeFile("packages/regtest/foo/parth.das", "[package]\nname = \"foo\"\nversion = \"1.2.0\"\n\n[dependencies]\n");
    mkdir("packages/regtest/foo");
    writeFile("packages/regtest/foo/parth.das", "[package]\nname = \"foo\"\nversion = \"1.2.0\"\n\n[dependencies]\n");

    // Store string data, then call parseDasConfig
    set preStr: string = "this_should_survive";
    set buf: string = getStateBuf();
    set r: int = parseDasConfig("packages/regtest/parth.das");
    // The string variable preStr must still be intact (arena-owned, not buffer)
    if (strcmp_ajeeb(preStr, "this_should_survive") == 0) {
        println("  ✓ R3a: String vars survive parseDasConfig (no buffer aliasing)");
        passed = passed + 1;
    } else {
        println("  ✗ R3a: Buffer aliasing corrupted string variable!");
        failed = failed + 1;
    }
    // Verify parseDasConfig still worked
    set src: string = readFile("packages/regtest/parth.das");
    set pkgName: string = getConfigName(buf, src);
    if (strcmp_ajeeb(pkgName, "regtest") == 0) {
        println("  ✓ R3b: parseDasConfig still works after string storage");
        passed = passed + 1;
    } else {
        println("  ✗ R3b: parseDasConfig broken after string storage");
        failed = failed + 1;
    }

    // ── R4: Visited-set works in resolveAll ─────────────────
    writeFile("parth.das", "[package]\nname = \"rvtest\"\nversion = \"0.1.0\"\n\n[dependencies]\nregtest = \"^1.0.0\"\n\n[compiler]\ntarget = \"native\"\noutput = \"build/\"\nruntime = \"runtime/ajeeb_runtime.c\"\n");
    set rBuf: string = getStateBuf();
    set rR: int = parseDasConfig("parth.das");
    set rSrc: string = readFile("parth.das");
    set rr: int = resolveAll(rBuf, rSrc);
    // Should resolve without conflict (single dep)
    if (rr == 0) {
        println("  ✓ R4: Visited-set dedup works (no false conflicts)");
        passed = passed + 1;
    } else {
        println("  ✗ R4: Visited-set false conflict detected!");
        failed = failed + 1;
    }

    // Cleanup
    exec("rm -rf packages/regtest");
    exec("rm -f parth.das");

    set total: string = str_concat(itoa(passed), " passed, ");
    total = str_concat(total, str_concat(itoa(failed), " failed"));
    println(total);
    if (failed > 0) { return 1; }
    return 0;
}

// ═══════════════════════════════════════════════════════════════
// Suite 4: CSV Helpers
// ═══════════════════════════════════════════════════════════════

function testCsv(): int {
    set passed: int = 0;
    set failed: int = 0;

    // csvLen
    if (csvLen("") == 0) {
        println("  ✓ csvLen(\"\") == 0"); passed = passed + 1;
    } else { println("  ✗ csvLen(\"\") failed"); failed = failed + 1; }

    if (csvLen("a") == 1) {
        println("  ✓ csvLen(\"a\") == 1"); passed = passed + 1;
    } else { println("  ✗ csvLen(\"a\") failed"); failed = failed + 1; }

    if (csvLen("a,b,c") == 3) {
        println("  ✓ csvLen(\"a,b,c\") == 3"); passed = passed + 1;
    } else { println("  ✗ csvLen(\"a,b,c\") failed"); failed = failed + 1; }

    // csvGet
    if (strcmp_ajeeb(csvGet("alpha,beta,gamma", 0), "alpha") == 0) {
        println("  ✓ csvGet(0) == \"alpha\""); passed = passed + 1;
    } else { println("  ✗ csvGet(0) failed"); failed = failed + 1; }

    if (strcmp_ajeeb(csvGet("alpha,beta,gamma", 1), "beta") == 0) {
        println("  ✓ csvGet(1) == \"beta\""); passed = passed + 1;
    } else { println("  ✗ csvGet(1) failed"); failed = failed + 1; }

    if (strcmp_ajeeb(csvGet("alpha,beta,gamma", 2), "gamma") == 0) {
        println("  ✓ csvGet(2) == \"gamma\""); passed = passed + 1;
    } else { println("  ✗ csvGet(2) failed"); failed = failed + 1; }

    if (strcmp_ajeeb(csvGet("alpha,beta,gamma", 3), "") == 0) {
        println("  ✓ csvGet(3) == \"\" (out of bounds)"); passed = passed + 1;
    } else { println("  ✗ csvGet(3) should be empty"); failed = failed + 1; }

    // csvContains
    if (csvContains("a,b,c", "b") == 1) {
        println("  ✓ csvContains hit"); passed = passed + 1;
    } else { println("  ✗ csvContains miss"); failed = failed + 1; }

    if (csvContains("a,b,c", "d") == 0) {
        println("  ✓ csvContains reject"); passed = passed + 1;
    } else { println("  ✗ csvContains false positive"); failed = failed + 1; }

    set total: string = str_concat(itoa(passed), " passed, ");
    total = str_concat(total, str_concat(itoa(failed), " failed"));
    println(total);
    if (failed > 0) { return 1; }
    return 0;
}

// ═══════════════════════════════════════════════════════════════
// Suite 5: Config Parser
// ═══════════════════════════════════════════════════════════════

function testConfigParser(): int {
    set passed: int = 0;
    set failed: int = 0;

    mkdir("packages");
    mkdir("packages/cpptest");

    // Test config with all sections
    writeFile("packages/cpptest/parth.das", "[package]\nname = \"cpptest\"\nversion = \"2.3.1\"\nauthor = \"testuser\"\n\n[dependencies]\nfoo = \"^1.0.0\"\nbar = \"~2.1.0\"\n\n[compiler]\ntarget = \"native\"\noutput = \"build/\"\nruntime = \"runtime/ajeeb_runtime.c\"\n");

    set buf: string = getStateBuf();
    set r: int = parseDasConfig("packages/cpptest/parth.das");
    if (r == 0) {
        println("  ✓ Config parsed"); passed = passed + 1;
    } else { println("  ✗ Config parse failed"); failed = failed + 1; }

    set src: string = readFile("packages/cpptest/parth.das");

    // Package fields
    if (strcmp_ajeeb(getConfigName(buf, src), "cpptest") == 0) {
        println("  ✓ name = \"cpptest\""); passed = passed + 1;
    } else { println("  ✗ name mismatch"); failed = failed + 1; }

    if (strcmp_ajeeb(getConfigVersion(buf, src), "2.3.1") == 0) {
        println("  ✓ version = \"2.3.1\""); passed = passed + 1;
    } else { println("  ✗ version mismatch"); failed = failed + 1; }

    if (strcmp_ajeeb(getConfigAuthor(buf, src), "testuser") == 0) {
        println("  ✓ author = \"testuser\""); passed = passed + 1;
    } else { println("  ✗ author mismatch"); failed = failed + 1; }

    // Dependencies
    set dc: int = getDepCount(buf);
    if (dc == 2) {
        println("  ✓ dep count = 2"); passed = passed + 1;
    } else { println(str_concat("  ✗ dep count = ", itoa(dc))); failed = failed + 1; }

    if (strcmp_ajeeb(getDepName(buf, src, 0), "foo") == 0 && strcmp_ajeeb(getDepVersion(buf, src, 0), "^1.0.0") == 0) {
        println("  ✓ dep[0] = foo@^1.0.0"); passed = passed + 1;
    } else { println("  ✗ dep[0] mismatch"); failed = failed + 1; }

    if (strcmp_ajeeb(getDepName(buf, src, 1), "bar") == 0 && strcmp_ajeeb(getDepVersion(buf, src, 1), "~2.1.0") == 0) {
        println("  ✓ dep[1] = bar@~2.1.0"); passed = passed + 1;
    } else { println("  ✗ dep[1] mismatch"); failed = failed + 1; }

    // Compiler fields
    if (strcmp_ajeeb(getCompilerTarget(buf, src), "native") == 0) {
        println("  ✓ target = \"native\""); passed = passed + 1;
    } else { println("  ✗ target mismatch"); failed = failed + 1; }

    // Empty deps config
    writeFile("packages/cpptest/nodeps.das", "[package]\nname = \"nodeps\"\nversion = \"0.1.0\"\n\n[dependencies]\n");
    set r2: int = parseDasConfig("packages/cpptest/nodeps.das");
    if (r2 == 0 && getDepCount(buf) == 0) {
        println("  ✓ Empty deps parsed"); passed = passed + 1;
    } else { println("  ✗ Empty deps failed"); failed = failed + 1; }

    // parseSpec
    if (strcmp_ajeeb(parseSpec("foo@^1.0.0"), "foo@^1.0.0") == 0) {
        println("  ✓ parseSpec(\"foo@^1.0.0\")"); passed = passed + 1;
    } else { println("  ✗ parseSpec with @ failed"); failed = failed + 1; }

    if (strcmp_ajeeb(parseSpec("bar"), "bar@*") == 0) {
        println("  ✓ parseSpec(\"bar\") => \"bar@*\""); passed = passed + 1;
    } else { println("  ✗ parseSpec default version failed"); failed = failed + 1; }

    exec("rm -rf packages/cpptest");

    set total: string = str_concat(itoa(passed), " passed, ");
    total = str_concat(total, str_concat(itoa(failed), " failed"));
    println(total);
    if (failed > 0) { return 1; }
    return 0;
}

// ═══════════════════════════════════════════════════════════════
// Suite 6-11: End-to-End Tests
// ═══════════════════════════════════════════════════════════════

function testE2ENew(): int {
    set passed: int = 0;
    set failed: int = 0;
    set testDir: string = "/tmp/parth_e2e_new";

    exec(str_concat("rm -rf ", testDir));
    set r: int = exec(str_concat("mkdir -p ", testDir));

    // Create new project inside testDir
    r = exec(str_concat("cd ", str_concat(testDir, " && /root/ajeeb_compiler/build/parth_m1 new myproj 2>&1")));
    if (r == 0) {
        println("  ✓ 'parth new' exited 0"); passed = passed + 1;
    } else { println("  ✗ 'parth new' failed"); failed = failed + 1; }

    // Verify files created
    set chk: int = exec(str_concat("test -f ", str_concat(testDir, "/myproj/parth.das && echo OK")));
    // Use readFile to check
    set dasContent: string = readFile(str_concat(testDir, "/myproj/parth.das"));
    if (len(dasContent) > 0) {
        println("  ✓ parth.das created"); passed = passed + 1;
    } else { println("  ✗ parth.das missing"); failed = failed + 1; }

    set srcContent: string = readFile(str_concat(testDir, "/myproj/src/main.ajb"));
    if (len(srcContent) > 0) {
        println("  ✓ src/main.ajb created"); passed = passed + 1;
    } else { println("  ✗ src/main.ajb missing"); failed = failed + 1; }

    // Verify parth.das has correct name
    set nameIdx: int = 0;
    set found: int = 0;
    while (nameIdx < len(dasContent)) {
        if (charCode(dasContent, nameIdx) == 109 && charCode(dasContent, nameIdx + 1) == 121 && charCode(dasContent, nameIdx + 2) == 112 && charCode(dasContent, nameIdx + 3) == 114 && charCode(dasContent, nameIdx + 4) == 111 && charCode(dasContent, nameIdx + 5) == 106) {
            found = 1;
        }
        nameIdx = nameIdx + 1;
    }
    if (found == 1) {
        println("  ✓ parth.das contains project name"); passed = passed + 1;
    } else { println("  ✗ project name missing in parth.das"); failed = failed + 1; }

    exec(str_concat("rm -rf ", testDir));

    set total: string = str_concat(itoa(passed), " passed, ");
    total = str_concat(total, str_concat(itoa(failed), " failed"));
    println(total);
    if (failed > 0) { return 1; }
    return 0;
}

