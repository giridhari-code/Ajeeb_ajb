function main(): int {
    set src: string = readFile("parth/tests/sample.parth.das");
    println(src);
    println(itoa(len(src)));
    set i: int = 0;
    while (i < len(src)) {
        set c: int = charCode(src, i);
        if (c == 10) { println("NEWLINE"); }
        i = i + 1;
    }
    return 0;
}
